---
interface Props {
  title: string;
  subtitle: string;
  description: string;
}

const { title, subtitle, description } = Astro.props;
---

<div class="text-center mt-12">
  <!-- Decorative Divider -->
  <div class="flex items-center justify-center mb-8 px-8">
    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
    <div class="mx-6 w-3 h-3 bg-green-500 rounded-full"></div>
    <div class="flex-1 h-px bg-gradient-to-r from-transparent via-gray-300 to-transparent"></div>
  </div>
  
  <h3 class="text-xl font-semibold text-gray-800 mb-4 sm:text-lg">{title}</h3>
  <p class="text-slate-600 mb-8 sm:text-sm">{subtitle}</p>
  
  <div class="mb-8 px-4">
    <p class="text-lg leading-relaxed text-slate-700 max-w-4xl mx-auto sm:text-base" set:html={description}></p>
  </div>
</div>

<style>
  @media (max-width: 640px) {
    .flex-1 {
      min-width: 20px;
    }
  }
</style>
