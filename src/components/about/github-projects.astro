---
import { Icon } from "astro-icon/components";

// Fetch repositories from GitHub API
let githubProjects = [];

try {
  const response = await fetch('https://api.github.com/orgs/masterfabric-mobile/repos?sort=updated&per_page=10');
  
  if (response.ok) {
    const repos = await response.json();
    
    githubProjects = repos.map(repo => ({
      name: repo.name,
      description: repo.description || "No description available",
      url: repo.html_url,
      language: repo.language || "Unknown",
      stars: repo.stargazers_count,
      forks: repo.forks_count,
      topics: repo.topics || [],
      updated_at: repo.updated_at
    }));
  } else {
    // Fallback data if API fails
    githubProjects = [
      {
        name: "masterfabric-website",
        description: "Official website for MasterFabric Inc. - Mobile app development company specializing in Flutter and React Native applications.",
        url: "https://github.com/masterfabric-mobile/masterfabric-website",
        language: "TypeScript",
        stars: 0,
        forks: 0,
        topics: ["astro", "tailwindcss", "typescript", "website", "mobile-company"]
      }
    ];
  }
} catch (error) {
  console.error('Error fetching GitHub repositories:', error);
  // Fallback data if API fails
  githubProjects = [
    {
      name: "masterfabric-website",
      description: "Official website for MasterFabric Inc. - Mobile app development company specializing in Flutter and React Native applications.",
      url: "https://github.com/masterfabric-mobile/masterfabric-website",
      language: "TypeScript",
      stars: 0,
      forks: 0,
      topics: ["astro", "tailwindcss", "typescript", "website", "mobile-company"]
    }
  ];
}

// Language colors mapping
const languageColors = {
  "TypeScript": "#3178c6",
  "Dart": "#0175c2",
  "JavaScript": "#f1e05a",
  "Shell": "#89e051",
  "Swift": "#fa7343",
  "Kotlin": "#a97bff",
  "Astro": "#ff5d01"
};
---

<section class="py-16 lg:py-20">
  <div class="text-center mb-12">
    <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-6">
      Open Source Projects
    </h2>
    <p class="text-lg text-gray-600 max-w-3xl mx-auto leading-relaxed">
      We believe in giving back to the developer community. Here are our 
      <span class="font-semibold text-blue-600">open source projects</span> that help developers 
      build better mobile applications faster.
    </p>
  </div>

  <!-- Vertical List of Horizontal Project Cards -->
  <div class="space-y-6 max-w-4xl mx-auto">
    {githubProjects.map((project, index) => (
      <div class="group bg-white rounded-xl p-6 border border-gray-100 shadow-sm hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
          <!-- Left Side: Project Info -->
          <div class="flex-1">
            <div class="flex items-start gap-4">
              <!-- GitHub Icon -->
              <div class="w-12 h-12 bg-gray-100 rounded-lg flex items-center justify-center group-hover:bg-blue-50 transition-colors duration-300 flex-shrink-0">
                <Icon class="w-6 h-6 text-gray-600 group-hover:text-blue-600 transition-colors duration-300" name="simple-icons:github" />
              </div>
              
              <!-- Project Details -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="text-xl font-semibold text-gray-900 group-hover:text-blue-600 transition-colors duration-300">
                    {project.name}
                  </h3>
                  <!-- Language Badge -->
                  <div class="flex items-center space-x-1 text-sm text-gray-500">
                    <div 
                      class="w-3 h-3 rounded-full" 
                      style={`background-color: ${languageColors[project.language] || '#888'}`}
                    ></div>
                    <span>{project.language}</span>
                  </div>
                </div>
                
                <p class="text-gray-600 text-sm leading-relaxed mb-3">
                  {project.description}
                </p>
                
                <!-- Topics -->
                <div class="flex flex-wrap gap-2 mb-3">
                  {project.topics.slice(0, 4).map((topic) => (
                    <span class="px-2 py-1 bg-blue-50 text-blue-700 text-xs rounded-md font-medium">
                      {topic}
                    </span>
                  ))}
                  {project.topics.length > 4 && (
                    <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded-md font-medium">
                      +{project.topics.length - 4}
                    </span>
                  )}
                </div>
                
                <!-- Stats -->
                <div class="flex items-center space-x-4 text-sm text-gray-500">
                  <div class="flex items-center space-x-1">
                    <Icon class="w-3 h-3" name="uil:star" />
                    <span>{project.stars} stars</span>
                  </div>
                  <div class="flex items-center space-x-1">
                    <Icon class="w-3 h-3" name="uil:code-branch" />
                    <span>{project.forks} forks</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Right Side: Action Button -->
          <div class="flex-shrink-0">
            <a 
              href={project.url} 
              target="_blank" 
              rel="noopener noreferrer"
              class="inline-flex items-center space-x-2 bg-gray-100 hover:bg-blue-50 text-gray-700 hover:text-blue-700 px-4 py-2 rounded-lg font-medium transition-all duration-300 group-hover:scale-105"
            >
              <span>View Project</span>
              <Icon class="w-4 h-4" name="uil:external-link-alt" />
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- GitHub Organization Link -->
  <div class="text-center mt-12">
    <a 
      href="https://github.com/masterfabric-mobile" 
      target="_blank" 
      rel="noopener noreferrer"
      class="inline-flex items-center space-x-2 bg-gray-900 hover:bg-gray-800 text-white px-6 py-3 rounded-xl font-semibold transition-all duration-300 hover:scale-105 hover:shadow-lg"
    >
      <Icon class="w-5 h-5" name="simple-icons:github" />
      <span>View All Projects on GitHub</span>
      <Icon class="w-4 h-4" name="uil:external-link-alt" />
    </a>
  </div>
</section>

<style>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
