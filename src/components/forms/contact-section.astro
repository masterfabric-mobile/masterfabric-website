---
// =============================================================================
// CONTACT SECTION COMPONENT
// Two-column layout with content on left and contact form on right
// =============================================================================
import Button from "@components/ui/button.astro";
import fs from "fs";
import path from "path";

// Load contact data from JSON file
const contactDataPath = path.join(process.cwd(), "src/data/contact.json");
const contactDataContent = fs.readFileSync(contactDataPath, "utf-8");
const contactData = JSON.parse(contactDataContent);
---

<section class="py-16 lg:py-24 bg-white" id="contact">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-16 items-start">
      
      <!-- LEFT COLUMN - CONTENT AREA -->
      <div class="space-y-8">
        <div class="space-y-6">
          <!-- Main Heading -->
          <h2 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-gray-900 leading-tight">
            <span class="block">{contactData.hero.title.line1}</span>
            <span class="block">{contactData.hero.title.line2}</span>
            <span class="block text-blue-600">{contactData.hero.title.line3}</span>
          </h2>
          
          <!-- Description Paragraph -->
          <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl" set:html={contactData.hero.description}>
          </p>
        </div>

        <!-- Additional Benefits -->
        <div class="grid sm:grid-cols-2 gap-6 pt-8">
          {contactData.benefits.map((benefit, index) => (
            <div class="flex items-start space-x-3 group">
              <div class="flex-shrink-0 relative">
                <div 
                  class="icon-container w-12 h-12 rounded-full flex items-center justify-center text-white text-xl transition-all duration-500 transform group-hover:scale-110 relative overflow-hidden cursor-pointer"
                  style={`background: linear-gradient(135deg, ${
                    index === 0 ? 'rgb(96, 165, 250), rgb(37, 99, 235)' :
                    index === 1 ? 'rgb(251, 191, 36), rgb(249, 115, 22)' :
                    index === 2 ? 'rgb(74, 222, 128), rgb(34, 197, 94)' :
                    'rgb(196, 181, 253), rgb(147, 51, 234)'
                  })`}
                >
                  <span class="relative z-20 transition-transform duration-300 group-hover:scale-110">
                    {index === 0 && (
                      <!-- Mobile/Phone Icon -->
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a1 1 0 001-1V4a1 1 0 00-1-1H8a1 1 0 00-1 1v16a1 1 0 001 1z"></path>
                      </svg>
                    )}
                    {index === 1 && (
                      <!-- Lightning/Speed Icon -->
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                      </svg>
                    )}
                    {index === 2 && (
                      <!-- Toolbox Support Icon -->
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <!-- Toolbox main body -->
                        <rect x="4" y="8" width="16" height="10" rx="2" stroke-width="2"/>
                        <!-- Toolbox handle -->
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 8V6a2 2 0 012-2h4a2 2 0 012 2v2"/>
                        <!-- Tool compartment line -->
                        <line x1="4" y1="12" x2="20" y2="12" stroke-width="2"/>
                        <!-- Tools inside - screwdriver and wrench representation -->
                        <circle cx="9" cy="15" r="1" fill="currentColor"/>
                        <circle cx="15" cy="15" r="1" fill="currentColor"/>
                      </svg>
                    )}
                    {index === 3 && (
                      <!-- Chart/Graph Icon for Scalable Solutions -->
                      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <!-- X and Y axis -->
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 20h16M4 20V4"/>
                        <!-- Growth line/trend -->
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 16l3-4 3 2 6-6"/>
                        <!-- Data points -->
                        <circle cx="6" cy="16" r="1.5" fill="currentColor"/>
                        <circle cx="9" cy="12" r="1.5" fill="currentColor"/>
                        <circle cx="12" cy="14" r="1.5" fill="currentColor"/>
                        <circle cx="18" cy="8" r="1.5" fill="currentColor"/>
                      </svg>
                    )}
                  </span>
                  
                  <!-- Ripple effects with dynamic colors -->
                  <div 
                    class="ripple-effect absolute inset-0 rounded-full opacity-0 group-hover:opacity-100"
                    style={`background: radial-gradient(circle, ${
                      index === 0 ? 'rgba(59, 130, 246, 0.4)' :
                      index === 1 ? 'rgba(251, 191, 36, 0.4)' :
                      index === 2 ? 'rgba(34, 197, 94, 0.4)' :
                      'rgba(147, 51, 234, 0.4)'
                    } 0%, ${
                      index === 0 ? 'rgba(59, 130, 246, 0.1)' :
                      index === 1 ? 'rgba(251, 191, 36, 0.1)' :
                      index === 2 ? 'rgba(34, 197, 94, 0.1)' :
                      'rgba(147, 51, 234, 0.1)'
                    } 50%, transparent 70%)`}
                  ></div>
                  
                  <div 
                    class="ripple-effect-2 absolute inset-0 rounded-full opacity-0 group-hover:opacity-100"
                    style={`background: radial-gradient(circle, ${
                      index === 0 ? 'rgba(59, 130, 246, 0.3)' :
                      index === 1 ? 'rgba(251, 191, 36, 0.3)' :
                      index === 2 ? 'rgba(34, 197, 94, 0.3)' :
                      'rgba(147, 51, 234, 0.3)'
                    } 0%, ${
                      index === 0 ? 'rgba(59, 130, 246, 0.08)' :
                      index === 1 ? 'rgba(251, 191, 36, 0.08)' :
                      index === 2 ? 'rgba(34, 197, 94, 0.08)' :
                      'rgba(147, 51, 234, 0.08)'
                    } 50%, transparent 70%)`}
                  ></div>
                  
                  <div 
                    class="ripple-effect-3 absolute inset-0 rounded-full opacity-0 group-hover:opacity-100"
                    style={`background: radial-gradient(circle, ${
                      index === 0 ? 'rgba(59, 130, 246, 0.2)' :
                      index === 1 ? 'rgba(251, 191, 36, 0.2)' :
                      index === 2 ? 'rgba(34, 197, 94, 0.2)' :
                      'rgba(147, 51, 234, 0.2)'
                    } 0%, ${
                      index === 0 ? 'rgba(59, 130, 246, 0.05)' :
                      index === 1 ? 'rgba(251, 191, 36, 0.05)' :
                      index === 2 ? 'rgba(34, 197, 94, 0.05)' :
                      'rgba(147, 51, 234, 0.05)'
                    } 50%, transparent 70%)`}
                  ></div>
                  
                  <!-- Color burst center -->
                  <div class="color-burst absolute inset-0 rounded-full opacity-0 group-hover:opacity-70"></div>
                  
                  <!-- Sparkle effects -->
                  <div class="sparkle sparkle-1 absolute opacity-0 group-hover:opacity-100"></div>
                  <div class="sparkle sparkle-2 absolute opacity-0 group-hover:opacity-100"></div>
                  <div class="sparkle sparkle-3 absolute opacity-0 group-hover:opacity-100"></div>
                  <div class="sparkle sparkle-4 absolute opacity-0 group-hover:opacity-100"></div>
                </div>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 group-hover:text-gray-700 transition-colors duration-300">{benefit.title}</h3>
                <p class="text-gray-600 text-sm group-hover:text-gray-500 transition-colors duration-300">{benefit.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- RIGHT COLUMN - CONTACT FORM -->
      <div class="lg:pl-8">
        <div class="bg-white border border-gray-200 rounded-2xl shadow-xl p-8 lg:p-10">
          
          <!-- Initial Stage - Call to Action -->
          <div id="initial-stage" class="stage-container text-center">
            <div class="mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">{contactData.form.stages.initial.title}</h3>
              <p class="text-gray-600">{contactData.form.stages.initial.subtitle}</p>
            </div>
            <Button 
              id="show-form-btn" 
              size="lg" 
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-lg transition-colors duration-200 w-full">
              {contactData.form.stages.initial.buttonText}
            </Button>
          </div>

          <!-- Return Visitor Notifications -->
          <div id="return-visitor-notification" class="stage-container hidden">
            <div id="notification-content" class="text-center space-y-4">
              <!-- Dynamic notification content will be inserted here -->
            </div>
          </div>

          <!-- Form Stage -->
          <div id="form-stage" class="stage-container hidden">
            <div class="mb-8">
              <h3 class="text-2xl font-bold text-gray-900 mb-2">{contactData.form.stages.form.title}</h3>
              <p class="text-gray-600">{contactData.form.stages.form.subtitle}</p>
            </div>
            
            <!-- Contact Form -->
            <form
              action={contactData.api.endpoint}
              method="POST"
              id="contact-form"
              class="needs-validation space-y-6"
              novalidate>
              
              <input type="hidden" name="access_key" value={contactData.api.accessKey} />
              <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
              
              <!-- Name Field -->
              <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-2">{contactData.form.fields.name.label}</label>
                <input
                  type={contactData.form.fields.name.type}
                  id="name"
                  name="name"
                  required={contactData.form.fields.name.required}
                  placeholder={contactData.form.fields.name.placeholder}
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400"
                />
                <div class="empty-feedback invalid-feedback text-red-500 text-sm mt-1">
                  {contactData.form.fields.name.validation.emptyMessage}
                </div>
              </div>

              <!-- Email Field -->
              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-2">{contactData.form.fields.email.label}</label>
                <input
                  type={contactData.form.fields.email.type}
                  id="email"
                  name="email"
                  required={contactData.form.fields.email.required}
                  placeholder={contactData.form.fields.email.placeholder}
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400"
                />
                <div class="empty-feedback text-red-500 text-sm mt-1">
                  {contactData.form.fields.email.validation.emptyMessage}
                </div>
                <div class="invalid-feedback text-red-500 text-sm mt-1">
                  {contactData.form.fields.email.validation.invalidMessage}
                </div>
              </div>

              <!-- Phone Field -->
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">{contactData.form.fields.phone.label}</label>
                <input
                  type={contactData.form.fields.phone.type}
                  id="phone"
                  name="phone"
                  placeholder={contactData.form.fields.phone.placeholder}
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400"
                />
              </div>

              <!-- Project Type Field -->
              <div>
                <label for="project-type" class="block text-sm font-medium text-gray-700 mb-2">{contactData.form.fields.projectType.label}</label>
                <select
                  id="project-type"
                  name="project-type"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200">
                  {contactData.form.fields.projectType.options.map((option) => (
                    <option value={option.value}>{option.text}</option>
                  ))}
                </select>
              </div>

              <!-- Message Field -->
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-2">{contactData.form.fields.message.label}</label>
                <textarea
                  id="message"
                  name="message"
                  required={contactData.form.fields.message.required}
                  rows={contactData.form.fields.message.rows}
                  placeholder={contactData.form.fields.message.placeholder}
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400 resize-vertical"></textarea>
                <div class="empty-feedback invalid-feedback text-red-500 text-sm mt-1">
                  {contactData.form.fields.message.validation.emptyMessage}
                </div>
              </div>

              <!-- Budget Range -->
              <div>
                <label for="budget" class="block text-sm font-medium text-gray-700 mb-2">{contactData.form.fields.budget.label}</label>
                <select
                  id="budget"
                  name="budget"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200">
                  {contactData.form.fields.budget.options.map((option) => (
                    <option value={option.value}>{option.text}</option>
                  ))}
                </select>
              </div>

              <!-- Form Actions -->
              <div class="flex flex-col gap-3">
                <Button 
                  type="submit" 
                  size="lg" 
                  class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-200 w-full">
                  {contactData.form.submitButton.text}
                </Button>
                <div class="text-center">
                  <button 
                    type="button" 
                    id="back-to-initial-btn"
                    class="text-gray-600 hover:text-gray-800 text-sm font-medium transition-colors duration-200">
                    ← Back
                  </button>
                </div>
              </div>

              <!-- Result Message -->
              <div id="form-result" class="text-center"></div>
            </form>
          </div>

          <!-- Success Stage -->
          <div id="success-stage" class="stage-container hidden text-center">
            <div class="mb-8">
              <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <h3 class="text-2xl font-bold text-gray-900 mb-2">{contactData.form.stages.success.title}</h3>
              <p class="text-gray-600">{contactData.form.stages.success.subtitle}</p>
            </div>
            <Button 
              id="back-to-home-btn"
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-lg transition-colors duration-200 w-full">
              {contactData.form.stages.success.backButtonText}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  /* Stage Transition Animations - Ultra Simplified */
  .stage-container {
    transition: opacity 0.2s ease;
    opacity: 1;
  }

  .stage-container.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .stage-container:not(.hidden) {
    opacity: 1;
    pointer-events: auto;
  }

  /* Form submission loading animation */
  .form-submitting {
    pointer-events: none;
    opacity: 0.7;
  }

  .form-submitting .submit-button {
    position: relative;
    overflow: hidden;
  }

  .form-submitting .submit-button::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: submitShimmer 1.5s infinite;
  }

  @keyframes submitShimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  /* Advanced Circular Animation Effects */
  @keyframes rippleOut {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(2.5);
      opacity: 0;
    }
  }

  @keyframes rippleOut2 {
    0% {
      transform: scale(1);
      opacity: 0.6;
    }
    100% {
      transform: scale(3);
      opacity: 0;
    }
  }

  @keyframes rippleOut3 {
    0% {
      transform: scale(1);
      opacity: 0.4;
    }
    100% {
      transform: scale(3.5);
      opacity: 0;
    }
  }

  @keyframes colorBurst {
    0% {
      transform: scale(0.5);
      opacity: 0;
      background: radial-gradient(circle, rgba(255,255,255,0.9) 0%, rgba(255,255,255,0.3) 40%, transparent 70%);
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
      background: radial-gradient(circle, rgba(255,255,255,0.7) 0%, rgba(255,255,255,0.2) 40%, transparent 70%);
    }
    100% {
      transform: scale(2);
      opacity: 0;
      background: radial-gradient(circle, rgba(255,255,255,0.4) 0%, rgba(255,255,255,0.1) 40%, transparent 70%);
    }
  }

  @keyframes sparkle {
    0%, 100% {
      transform: scale(0) rotate(0deg);
      opacity: 0;
    }
    50% {
      transform: scale(1) rotate(180deg);
      opacity: 1;
    }
  }

  .ripple-effect {
    animation: rippleOutOptimized 0.8s ease-out;
    animation-delay: 0s;
    will-change: transform, opacity;
  }

  .ripple-effect-2 {
    animation: rippleOut2Optimized 1s ease-out;
    animation-delay: 0.1s;
    will-change: transform, opacity;
  }

  .ripple-effect-3 {
    animation: rippleOut3Optimized 1.2s ease-out;
    animation-delay: 0.2s;
    will-change: transform, opacity;
  }

  .color-burst {
    animation: colorBurstOptimized 0.6s ease-out;
    animation-delay: 0.1s;
    will-change: transform, opacity;
  }

  .sparkle {
    width: 4px;
    height: 4px;
    background: white;
    border-radius: 50%;
    animation: sparkleOptimized 0.8s ease-in-out;
    will-change: transform, opacity;
  }

  .sparkle-1 {
    top: 20%;
    left: 80%;
    animation-delay: 0.2s;
  }

  .sparkle-2 {
    top: 80%;
    left: 20%;
    animation-delay: 0.3s;
  }

  .sparkle-3 {
    top: 30%;
    left: 10%;
    animation-delay: 0.4s;
  }

  .sparkle-4 {
    top: 70%;
    left: 90%;
    animation-delay: 0.1s;
  }
</style>

<script is:inline define:vars={{contactData}}>
  // Contact Form State Management with Performance Optimizations
  class ContactFormManager {
    constructor() {
      this.stages = {
        INITIAL: 'initial',
        FORM: 'form',
        SUCCESS: 'success',
        NOTIFICATION: 'notification'
      };
      
      this.currentStage = this.stages.INITIAL;
      this.contactData = contactData;
      this.isTransitioning = false;
      
      this.init();
    }

    init() {
      this.checkReturnVisitor();
      this.bindEvents();
    }

    checkReturnVisitor() {
      const contactHistory = this.getContactHistory();
      if (contactHistory.length > 0) {
        const lastContact = contactHistory[contactHistory.length - 1];
        const daysSinceContact = Math.floor((Date.now() - lastContact.timestamp) / (1000 * 60 * 60 * 24));
        
        let notificationType;
        if (daysSinceContact < 1) {
          notificationType = 'recent-contact';
        } else if (daysSinceContact < 3) {
          notificationType = 'pending-response';
        } else {
          notificationType = 'no-response';
        }
        
        this.showReturnVisitorNotification(notificationType);
      }
    }

    showReturnVisitorNotification(type) {
      const notification = this.contactData.form.returnVisitor.notifications.find(n => n.type === type);
      if (!notification) return;

      const notificationHtml = `
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
          <div class="flex items-center justify-center mb-4">
            <div class="text-3xl">${notification.icon}</div>
          </div>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">${notification.title}</h4>
          <p class="text-gray-600 mb-4">${notification.message}</p>
          <div class="flex gap-2 justify-center flex-wrap">
            ${notification.actions.map(action => `
              <button 
                class="px-4 py-2 text-sm font-medium rounded-lg transition-colors duration-200 ${
                  action.action === 'new-message' || action.action === 'resend' 
                    ? 'bg-blue-600 text-white hover:bg-blue-700' 
                    : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                }"
                onclick="contactFormManager.handleNotificationAction('${action.action}')">
                ${action.text}
              </button>
            `).join('')}
          </div>
        </div>
        <div class="text-center">
          <button 
            id="show-form-from-notification-btn"
            onclick="contactFormManager.clearCacheAndStartFresh()"
            class="text-blue-600 hover:text-blue-700 text-sm font-medium">
            Or start fresh
          </button>
        </div>
      `;

      document.getElementById('notification-content').innerHTML = notificationHtml;
      this.showStage(this.stages.NOTIFICATION);
    }

    handleNotificationAction(action) {
      switch(action) {
        case 'check-email':
          // Open default email client
          window.location.href = 'mailto:';
          break;
        case 'new-message':
        case 'resend':
          this.showStage(this.stages.FORM);
          break;
      }
    }

    bindEvents() {
      // Show form button
      const showFormBtn = document.getElementById('show-form-btn');
      if (showFormBtn) {
        showFormBtn.addEventListener('click', () => this.showStage(this.stages.FORM));
      }

      // Back to initial button
      const backToInitialBtn = document.getElementById('back-to-initial-btn');
      if (backToInitialBtn) {
        backToInitialBtn.addEventListener('click', () => this.showStage(this.stages.INITIAL));
      }

      // Back to home button
      const backToHomeBtn = document.getElementById('back-to-home-btn');
      if (backToHomeBtn) {
        backToHomeBtn.addEventListener('click', () => this.showStage(this.stages.INITIAL));
      }

      // Form submission
      const contactForm = document.getElementById('contact-form');
      if (contactForm) {
        contactForm.addEventListener('submit', (e) => this.handleFormSubmit(e));
      }
    }

    showStage(stage) {
      // Prevent rapid successive transitions
      if (this.isTransitioning) {
        return Promise.resolve();
      }

      const currentStageEl = this.getCurrentStageElement();
      const nextStageEl = this.getStageElement(stage);
      
      if (!nextStageEl || currentStageEl === nextStageEl) {
        return Promise.resolve();
      }

      this.isTransitioning = true;

      // Simple transition: hide current, show next
      return new Promise((resolve) => {
        // Hide current stage
        if (currentStageEl) {
          currentStageEl.classList.add('hidden');
        }

        // Show next stage
        nextStageEl.classList.remove('hidden');

        // Update current stage
        this.currentStage = stage;
        this.isTransitioning = false;
        
        resolve();
      });
    }

    getCurrentStageElement() {
      switch(this.currentStage) {
        case this.stages.INITIAL:
          return document.getElementById('initial-stage');
        case this.stages.FORM:
          return document.getElementById('form-stage');
        case this.stages.SUCCESS:
          return document.getElementById('success-stage');
        case this.stages.NOTIFICATION:
          return document.getElementById('return-visitor-notification');
        default:
          return document.getElementById('initial-stage');
      }
    }

    getStageElement(stage) {
      switch(stage) {
        case this.stages.INITIAL:
          return document.getElementById('initial-stage');
        case this.stages.FORM:
          return document.getElementById('form-stage');
        case this.stages.SUCCESS:
          return document.getElementById('success-stage');
        case this.stages.NOTIFICATION:
          return document.getElementById('return-visitor-notification');
        default:
          return null;
      }
    }

    getStageIndex(stage) {
      const stageOrder = [this.stages.INITIAL, this.stages.NOTIFICATION, this.stages.FORM, this.stages.SUCCESS];
      return stageOrder.indexOf(stage);
    }

    async handleFormSubmit(e) {
      e.preventDefault();
      const form = e.target;
      form.classList.add('was-validated');
      
      if (!form.checkValidity()) {
        form.querySelectorAll(':invalid')[0].focus();
        return;
      }

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      // Simple loading state management
      const submitButton = form.querySelector('button[type="submit"]');
      const formResult = document.getElementById('form-result');
      
      // Set loading state
      form.classList.add('form-submitting');
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = this.contactData.form.submitButton.loadingText;
      }

      formResult.innerHTML = `
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
          <p class="text-blue-800">
            <svg class="inline w-5 h-5 mr-2 animate-spin" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
            </svg>
            ${this.contactData.form.messages.sending.title}
          </p>
          <p class="text-blue-600 text-sm mt-1">${this.contactData.form.messages.sending.description}</p>
        </div>
      `;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: json,
        });

        const result = await response.json();
        
        if (response.status === 200) {
          // Save contact to history
          this.saveContactToHistory({
            email: object.email,
            timestamp: Date.now(),
            name: object.name
          });

          // Show success message
          formResult.innerHTML = `
            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
              <p class="text-green-800">
                <svg class="inline w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path>
                </svg>
                ${this.contactData.form.messages.success.title}
              </p>
              <p class="text-green-600 text-sm mt-1">${this.contactData.form.messages.success.description}</p>
            </div>
          `;

          // Transition to success stage
          setTimeout(() => {
            this.showStage(this.stages.SUCCESS);
          }, 1200);
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        // Reset loading state and show error
        form.classList.remove('form-submitting');
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = this.contactData.form.submitButton.text;
        }

        formResult.innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <p class="text-red-800">
              <svg class="inline w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"></path>
              </svg>
              ${this.contactData.form.messages.error.title}
            </p>
            <p class="text-red-600 text-sm mt-1">${this.contactData.form.messages.error.description}</p>
          </div>
        `;
      }
    }

    getContactHistory() {
      try {
        const history = localStorage.getItem('masterfabric_contact_history');
        return history ? JSON.parse(history) : [];
      } catch {
        return [];
      }
    }

    saveContactToHistory(contact) {
      try {
        const history = this.getContactHistory();
        history.push(contact);
        // Keep only last 5 contacts
        if (history.length > 5) {
          history.splice(0, history.length - 5);
        }
        localStorage.setItem('masterfabric_contact_history', JSON.stringify(history));
      } catch (error) {
        console.warn('Could not save contact history:', error);
      }
    }

    clearCacheAndStartFresh() {
      try {
        // Clear the contact history from localStorage
        localStorage.removeItem('masterfabric_contact_history');
        console.log('Contact history cache cleared');
        
        // Show the initial stage
        this.showStage(this.stages.INITIAL);
      } catch (error) {
        console.warn('Could not clear contact history:', error);
        // Still show initial stage even if cache clearing fails
        this.showStage(this.stages.INITIAL);
      }
    }
  }

  // Initialize when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    window.contactFormManager = new ContactFormManager();
  });

  // Initialize immediately if DOM is already loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      window.contactFormManager = new ContactFormManager();
    });
  } else {
    window.contactFormManager = new ContactFormManager();
  }
</script>

