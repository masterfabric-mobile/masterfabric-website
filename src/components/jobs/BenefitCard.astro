---
import { Icon } from "astro-icon/components";

interface Props {
  benefit: {
    title: string;
    description: string;
    iconName?: string;
  };
}

const { benefit } = Astro.props;
---

<div class="text-center p-6 bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300">
  <div class="w-16 h-16 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
    {benefit.iconName ? (
      <Icon name={benefit.iconName} class="w-8 h-8 text-blue-600" />
    ) : benefit.title.toLowerCase().includes('health') || benefit.title.toLowerCase().includes('medical') ? (
      <Icon name="bx:plus-medical" class="w-8 h-8 text-blue-600" />
    ) : benefit.title.toLowerCase().includes('balance') || benefit.title.toLowerCase().includes('time') ? (
      <Icon name="bx:time-five" class="w-8 h-8 text-blue-600" />
    ) : benefit.title.toLowerCase().includes('growth') || benefit.title.toLowerCase().includes('career') ? (
      <Icon name="bx:trending-up" class="w-8 h-8 text-blue-600" />
    ) : benefit.title.toLowerCase().includes('remote') || benefit.title.toLowerCase().includes('flexible') ? (
      <Icon name="bx:home" class="w-8 h-8 text-blue-600" />
    ) : benefit.title.toLowerCase().includes('bonus') || benefit.title.toLowerCase().includes('salary') ? (
      <Icon name="bx:money" class="w-8 h-8 text-blue-600" />
    ) : benefit.title.toLowerCase().includes('team') || benefit.title.toLowerCase().includes('culture') ? (
      <Icon name="bx:group" class="w-8 h-8 text-blue-600" />
    ) : (
      <Icon name="bx:star" class="w-8 h-8 text-blue-600" />
    )}
  </div>
  <h3 class="text-lg font-bold text-gray-900 mb-3">{benefit.title}</h3>
  <p class="text-gray-600">{benefit.description}</p>
</div>
