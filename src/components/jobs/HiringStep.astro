---
import { Icon } from "astro-icon/components";

interface Props {
  step: {
    number: number;
    title: string;
    duration: string;
    description: string;
    details: string[];
    iconName?: string;
  };
  isLast?: boolean;
}

const { step, isLast = false } = Astro.props;
---

<div class="text-center px-2 flex-shrink-0 w-64 sm:w-72 md:w-80">
  <!-- Step Circle -->
  <div class="relative mb-6">
    <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-700 text-white rounded-full flex items-center justify-center font-bold text-base mx-auto relative z-10 border-3 border-white shadow-lg shadow-blue-200/50">
      {step.number}
    </div>
  </div>
  
  <!-- Step Content -->
  <div class="bg-white rounded-xl shadow-lg border border-blue-100 hover:shadow-xl transition-all duration-300 overflow-hidden hiring-step-card cursor-pointer w-full h-auto min-h-[240px] mt-4">
    <!-- Collapsed View -->
    <div class="p-4 sm:p-5 card-content">
      <!-- Icon (Clickable) -->
      <div 
        class="w-14 h-14 sm:w-16 sm:h-16 bg-gradient-to-br from-blue-50 via-indigo-50 to-blue-100 rounded-lg flex items-center justify-center mx-auto mb-3 border border-blue-100 shadow-sm hover:shadow-md hover:scale-105 transition-all duration-300"
      >
        {step.iconName ? (
          <Icon name={step.iconName} class="w-7 h-7 sm:w-8 sm:h-8 text-blue-600 hover:text-blue-700 transition-colors duration-300" />
        ) : step.title.toLowerCase().includes('application') || step.title.toLowerCase().includes('apply') ? (
          <Icon name="bx:file-blank" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-600 hover:text-blue-700 transition-colors duration-300" />
        ) : step.title.toLowerCase().includes('phone') || step.title.toLowerCase().includes('call') ? (
          <Icon name="bx:phone-call" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-600 hover:text-blue-700 transition-colors duration-300" />
        ) : step.title.toLowerCase().includes('interview') || step.title.toLowerCase().includes('meeting') ? (
          <Icon name="bx:video" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-600 hover:text-blue-700 transition-colors duration-300" />
        ) : step.title.toLowerCase().includes('technical') || step.title.toLowerCase().includes('test') ? (
          <Icon name="bx:code-curly" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-600 hover:text-blue-700 transition-colors duration-300" />
        ) : step.title.toLowerCase().includes('decision') || step.title.toLowerCase().includes('final') ? (
          <Icon name="bx:check-double" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-600 hover:text-blue-700 transition-colors duration-300" />
        ) : (
          <Icon name="bx:user-check" class="w-7 h-7 sm:w-8 sm:h-8 text-blue-600 hover:text-blue-700 transition-colors duration-300" />
        )}
      </div>
      
      <!-- Title -->
      <h3 class="text-base sm:text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
      
      <!-- Duration Badge -->
      <div class="inline-flex items-center px-2.5 py-1 bg-gradient-to-r from-blue-50 to-indigo-50 rounded-full border border-blue-100 mb-3">
        <Icon name="bx:time-five" class="w-3.5 h-3.5 text-blue-500 mr-1" />
        <span class="text-xs sm:text-sm text-blue-700 font-medium">{step.duration}</span>
      </div>
    </div>
    
    <!-- Expanded Content -->
    <div class="expanded-content px-4 sm:px-5 pb-4 sm:pb-5 max-h-0 overflow-hidden transition-all duration-500 ease-in-out opacity-0">
      <div class="border-t border-gray-100 pt-3 space-y-3">
        <p class="text-gray-600 text-xs sm:text-sm leading-relaxed">{step.description}</p>
        
        <div class="space-y-2">
          {step.details.map((detail) => (
            <div class="text-xs sm:text-sm text-gray-600 bg-gray-50 rounded-lg p-2.5 sm:p-3 border border-gray-100 leading-relaxed">
              <span class="break-words">{detail}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
    
    <!-- Expand/Collapse Indicator -->
    <div class="px-4 sm:px-5 pb-3">
      <button class="expand-btn w-full flex items-center justify-center py-1.5 text-blue-600 hover:text-blue-700 transition-colors duration-200">
        <Icon name="bx:chevron-down" class="w-4 h-4 transition-transform duration-300 chevron-icon" />
      </button>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const cards = document.querySelectorAll('.hiring-step-card');
    
    cards.forEach(card => {
      const cardContent = card.querySelector('.card-content');
      const expandBtn = card.querySelector('.expand-btn');
      const expandedContent = card.querySelector('.expanded-content');
      const chevronIcon = card.querySelector('.chevron-icon');
      let isExpanded = false;
      
      function toggleCard(e) {
        e.stopPropagation();
        
        if (isExpanded) {
          // Collapse
          expandedContent.style.maxHeight = '0px';
          expandedContent.style.opacity = '0';
          chevronIcon.style.transform = 'rotate(0deg)';
          isExpanded = false;
        } else {
          // Expand
          expandedContent.style.maxHeight = expandedContent.scrollHeight + 20 + 'px';
          expandedContent.style.opacity = '1';
          chevronIcon.style.transform = 'rotate(180deg)';
          isExpanded = true;
        }
      }
      
      cardContent.addEventListener('click', toggleCard);
      expandBtn.addEventListener('click', toggleCard);
    });
  });
</script>
