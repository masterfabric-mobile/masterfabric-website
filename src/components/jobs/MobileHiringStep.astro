---
import { Icon } from "astro-icon/components";

interface Props {
  step: {
    number: number;
    title: string;
    duration: string;
    description: string;
    details: string[];
    iconName?: string;
  };
  isLast: boolean;
}

const { step, isLast } = Astro.props;
---

<div class="relative">
  {!isLast && (
    <div class="absolute left-6 top-16 w-0.5 h-full bg-blue-200">
      <div class="w-full bg-blue-600"></div>
    </div>
  )}
  
  <div class="flex">
    <!-- Step Circle -->
    <div class="flex-shrink-0 w-12 h-12 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold text-lg relative z-10 border-4 border-blue-200">
      {step.number}
    </div>
    
    <!-- Step Content -->
    <div class="ml-6 mr-6 bg-white rounded-2xl p-6 shadow-lg border-2 border-blue-200 flex-1">
      <div class="w-12 h-12 bg-gradient-to-br from-blue-100 to-indigo-100 rounded-xl flex items-center justify-center mx-auto mb-4 border border-blue-200">
        {step.iconName ? (
          <Icon name={step.iconName} class="w-6 h-6 text-blue-600" />
        ) : step.title.toLowerCase().includes('application') || step.title.toLowerCase().includes('apply') ? (
          <Icon name="bx:file-blank" class="w-6 h-6 text-blue-600" />
        ) : step.title.toLowerCase().includes('phone') || step.title.toLowerCase().includes('call') ? (
          <Icon name="bx:phone-call" class="w-6 h-6 text-blue-600" />
        ) : step.title.toLowerCase().includes('interview') || step.title.toLowerCase().includes('meeting') ? (
          <Icon name="bx:video" class="w-6 h-6 text-blue-600" />
        ) : step.title.toLowerCase().includes('technical') || step.title.toLowerCase().includes('test') ? (
          <Icon name="bx:code-curly" class="w-6 h-6 text-blue-600" />
        ) : step.title.toLowerCase().includes('decision') || step.title.toLowerCase().includes('final') ? (
          <Icon name="bx:check-double" class="w-6 h-6 text-blue-600" />
        ) : (
          <Icon name="bx:user-check" class="w-6 h-6 text-blue-600" />
        )}
      </div>
      <h3 class="text-lg font-bold text-gray-900 mb-2">{step.title}</h3>
      <p class="text-sm text-blue-600 font-medium mb-3">{step.duration}</p>
      <p class="text-gray-600 text-sm mb-4">{step.description}</p>
      
      <div class="space-y-2">
        {step.details.map((detail) => (
          <div class="flex items-center text-xs text-gray-500">
            <Icon name="bx:check-circle" class="w-3 h-3 text-blue-500 mr-2 flex-shrink-0" />
            <span>{detail}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>
