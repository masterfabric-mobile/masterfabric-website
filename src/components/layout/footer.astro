<link rel="stylesheet" href="/src/styles/footer.css">

<footer class="bg-white">
  <!-- Modern Top Divider -->
  <div class="footer-divider">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="divider-line"></div>
    </div>
  </div>
  
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Simplified Single Section -->
    <div class="py-12 lg:py-16">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6">
        
        <!-- Brand and Description -->
        <div class="text-center md:text-left max-w-md">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">MasterFabric Information Technology Inc.</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            Crafting exceptional mobile applications with cutting-edge technology.
          </p>
          
          <!-- Compact Tech Credit -->
          <div class="astro-credit mt-3">
            <span class="built-with">Built with</span>
            <a 
              href="https://astro.build" 
              target="_blank" 
              rel="noopener noreferrer"
              class="astro-link"
            >
              <svg class="astro-icon" viewBox="0 0 256 366" xmlns="http://www.w3.org/2000/svg">
                <defs>
                  <linearGradient id="astroGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#FF5D01"/>
                    <stop offset="100%" style="stop-color:#FF1639"/>
                  </linearGradient>
                </defs>
                <path fill="url(#astroGradient)" d="M182.022 9.147c2.982 3.702 4.502 8.697 7.543 18.687L256 246.074a276.467 276.467 0 0 0-79.426-26.891L133.318 73.008a5.63 5.63 0 0 0-10.802.017L79.784 219.11A276.453 276.453 0 0 0 0 246.04L66.76 27.783c3.051-9.972 4.577-14.959 7.559-18.654a24.541 24.541 0 0 1 9.946-7.358C88.67 0 93.885 0 104.314 0h47.683c10.443 0 15.664 0 20.074 1.774a24.545 24.545 0 0 1 9.95 7.373Z"/>
                <path fill="#FF5D01" d="M189.972 256.46c-10.952 9.364-32.812 15.751-57.992 15.751-30.904 0-56.807-9.621-63.68-22.56-2.458 7.415-3.009 15.903 0 21.8 7.681 15.138 36.32 23.75 63.68 23.75 27.557 0 56.817-8.695 63.992-23.75 2.628-5.512 2.628-12.944 0-18.234a58.12 58.12 0 0 1-6.0 3.243Z"/>
              </svg>
              <span class="astro-text">Astro</span>
            </a>
          </div>
        </div>

        <!-- Compact Navigation and Legal -->
        <div class="flex flex-col md:flex-row items-center gap-4 md:gap-8">
          <!-- Quick Links -->
          <div class="flex flex-wrap justify-center gap-4 md:gap-6">
            <a href="/about" class="footer-link">About</a>
            <a href="/contact" class="footer-link">Contact</a>
            
            <a 
              href="https://github.com/masterfabric-mobile/masterfabric-website"
              target="_blank"
              rel="noopener noreferrer"
              class="footer-link"
            >
              Source
            </a>
            <button
              id="footer-cookie-settings"
              class="footer-link"
            >
              Cookies
            </button>
          </div>
          
          <!-- Legal Links -->
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/terms-of-use" class="footer-legal-link">Terms</a>
            <a href="/privacy-policy" class="footer-legal-link">Privacy</a>
          </div>
        </div>
      </div>
      
      <!-- Copyright - Minimal -->
      <div class="text-center mt-8 pt-6 border-t border-gray-50">
        <p class="text-xs text-gray-400">
          © {new Date().getFullYear()} MasterFabric Inc.
        </p>
      </div>
    </div>
  </div>
</footer>

<script src="/src/scripts/footer.js"></script>
