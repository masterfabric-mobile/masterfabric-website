---
// =============================================================================
// IMPORTS
// =============================================================================
import { Icon } from "astro-icon/components";

// =============================================================================
// TYPE DEFINITIONS
// =============================================================================
export interface Props {
  items: Array<{
    title: string;
    path: string;
    description?: string;
  }>;
  trigger: string;
  isMobile?: boolean;
  isActive?: boolean;
  currentPath?: string;
}

// =============================================================================
// COMPONENT PROPS & SETUP
// =============================================================================
const { items, trigger, isMobile = false, isActive = false, currentPath = '' } = Astro.props;

// Generate unique dropdown ID based on trigger text
const dropdownId = `dropdown-${trigger.toLowerCase().replace(/\s+/g, '-')}`;

// Helper function to check if item is current page
const isCurrentPage = (itemPath: string) => {
  const normalizeCurrentPath = currentPath === '/' ? '/' : currentPath.replace(/\/$/, '');
  const normalizeItemPath = itemPath === '/' ? '/' : itemPath.replace(/\/$/, '');
  return normalizeCurrentPath === normalizeItemPath;
};
---

<!-- ======================================================================= -->
<!-- DROPDOWN CONTAINER -->
<!-- ======================================================================= -->
<div class={`relative group ${isMobile ? 'w-full' : ''}`}>
  <!-- Dropdown trigger button -->
  <button
    type="button"
    class={`
      inline-flex items-center gap-1 px-4 py-2 text-sm font-medium rounded-lg
      transition-colors duration-200 relative
      ${isMobile 
        ? 'w-full justify-between hover:bg-gray-50 bg-gray-50' 
        : 'hover:bg-gray-50'
      }
      ${isActive 
        ? 'text-blue-600 bg-blue-50 border border-blue-200 navbar-active-dropdown' 
        : 'text-gray-700 hover:text-gray-900'
      }
    `}
    data-dropdown-toggle={dropdownId}
  >
    <!-- Button text -->
    <span>{trigger}</span>
    
    <!-- Active indicator -->
    {isActive && (
      <span class="w-2 h-2 bg-blue-500 rounded-full animate-pulse"></span>
    )}
    
    <!-- Chevron icon with rotation animation -->
    <Icon 
      name="bx:chevron-down" 
      class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" 
    />
  </button>

  <!-- ===================================================================== -->
  <!-- DROPDOWN MENU CONTENT -->
  <!-- ===================================================================== -->
  <div
    id={dropdownId}
    class={`
      absolute z-50 bg-white rounded-lg shadow-lg border border-gray-200
      opacity-0 invisible group-hover:opacity-100 group-hover:visible
      transition-all duration-200 transform
      ${isMobile 
        ? 'top-full left-0 right-0 mt-1 w-full max-w-xs mx-auto' 
        : 'top-full left-0 mt-1 w-64'
      }
    `}
  >
    <!-- Dropdown items container -->
    <div class="py-2">
      {items.map((item) => {
        const isItemActive = isCurrentPage(item.path);
        return (
          <!-- Individual dropdown item -->
          <a
            href={isItemActive ? undefined : item.path}
            class={`
              block px-4 py-3 text-sm transition-colors duration-150 relative
              ${isItemActive 
                ? 'bg-blue-50 text-blue-600 cursor-default border-l-4 border-blue-500 font-semibold active-dropdown-item' 
                : 'text-gray-700 hover:bg-gray-50 hover:text-gray-900 cursor-pointer'
              }
            `}
            {...(isItemActive && { 'aria-current': 'page' })}
          >
            <!-- Item title -->
            <div class="font-medium flex items-center justify-between">
              {item.title}
              {isItemActive && (
                <span class="ml-2 w-2 h-2 bg-blue-500 rounded-full"></span>
              )}
            </div>
            
            <!-- Optional item description -->
            {item.description && (
              <div class={`text-xs mt-1 ${isItemActive ? 'text-blue-500' : 'text-gray-500'}`}>
                {item.description}
              </div>
            )}
            
            <!-- Current page indicator -->
            {isItemActive && (
              <div class="text-xs text-blue-500 mt-1 font-medium">• Current Page</div>
            )}
          </a>
        );
      })}
    </div>
  </div>
</div>

<script>
  // ==========================================================================
  // DROPDOWN FUNCTIONALITY
  // ==========================================================================
  
  /**
   * Initialize dropdown toggle functionality when DOM is ready
   */
  document.addEventListener('DOMContentLoaded', () => {
    // Get all dropdown toggle buttons
    const dropdownButtons = document.querySelectorAll('[data-dropdown-toggle]');
    
    // Initialize each dropdown
    dropdownButtons.forEach(button => {
      const dropdownId = button.getAttribute('data-dropdown-toggle');
      const dropdown = document.getElementById(dropdownId);
      
      // Ensure dropdown element exists
      if (dropdown) {
        // Handle button click to toggle dropdown
        button.addEventListener('click', (e) => {
          e.preventDefault();
          toggleDropdown(dropdown);
        });
        
        // Handle click outside to close dropdown
        document.addEventListener('click', (e) => {
          if (!button.contains(e.target) && !dropdown.contains(e.target)) {
            closeDropdown(dropdown);
          }
        });
      }
    });
  });

  /**
   * Toggle dropdown visibility
   * @param {HTMLElement} dropdown - The dropdown element to toggle
   */
  function toggleDropdown(dropdown) {
    dropdown.classList.toggle('opacity-0');
    dropdown.classList.toggle('invisible');
  }

  /**
   * Close dropdown by adding hidden classes
   * @param {HTMLElement} dropdown - The dropdown element to close
   */
  function closeDropdown(dropdown) {
    dropdown.classList.add('opacity-0');
    dropdown.classList.add('invisible');
  }
</script>
