---
// =============================================================================
// IMPORTS
// =============================================================================
import Container from "@components/layout/container.astro";
import Link from "@components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Picture } from "astro:assets";
import Icon from "@components/ui/icon.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import masterFabricPicture from "assets/masterfabric-logo.svg";
import fs from "fs";
import path from "path";


// =============================================================================
// DATA LOADING & PROCESSING
// =============================================================================
// Load navigation configuration from JSON file
const navigationDataPath = path.join(process.cwd(), "src/data/navigation.json");
const navigationData = JSON.parse(fs.readFileSync(navigationDataPath, "utf-8"));

// Destructure navigation data
const { brand, menuItems, socialLinks, responsive } = navigationData;

// Sort menu items and social links by order
const sortedMenuItems = menuItems.sort((a, b) => a.order - b.order);
const sortedSocialLinks = socialLinks.sort((a, b) => a.order - b.order);

// =============================================================================
// SOCIAL ICON DEFINITIONS
// =============================================================================
// SVG path definitions for social media icons
const socialIcons = {
  github: "M12 0C5.374 0 0 5.373 0 12 0 17.302 3.438 21.8 8.207 23.387c.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z",
  linkedin: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
};
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-2 lg:my-5">
    <Astronav>
      <!-- =================================================================== -->
      <!-- BRAND SECTION - Logo and Company Info -->
      <!-- =================================================================== -->
      <div class="flex w-full lg:w-auto items-center justify-between py-2 lg:py-0">
        <!-- Brand Link with Logo and Text -->
        <a href="/" class="flex items-center group flex-shrink-0">
          <!-- Logo with hover animation -->
          <span class="inline-block mr-3 transition-transform duration-200 group-hover:scale-110">
            <Picture
              src={masterFabricPicture}
              alt={brand.alt}
              width={50}
              sizes="(max-width: 640px) 40px, (max-width: 1024px) 45px, 50px"
              loading="eager"
              format="avif"
              class="w-10 h-10 sm:w-11 sm:h-11 lg:w-12 lg:h-12"
            />
          </span>
          
          <!-- Brand text and description -->
          <div class="flex flex-col">
            <!-- Company name with gradient effect -->
            <div class="flex items-baseline">
              <span class="font-bold font-mono text-xl sm:text-2xl lg:text-4xl text-slate-800">
                {brand.text.main}
              </span>
              <span class="font-mono text-slate-500 text-xl sm:text-2xl lg:text-3xl">
                {brand.text.secondary}
              </span>
              <span class="font-mono text-slate-300 text-xl sm:text-2xl lg:text-3xl">
                {brand.text.tertiary}
              </span>
            </div>
            
            <!-- Company tagline -->
            <div class="font-mono text-xs sm:text-sm text-slate-400 mt-1">
              <span>{brand.description.platform} </span>
              <span class="font-bold text-slate-500">{brand.description.studio}</span>
            </div>
          </div>
        </a>
        
        <!-- Mobile menu toggle button -->
        <div class="block lg:hidden flex-shrink-0 ml-4">
          <MenuIcon class="w-6 h-6 text-gray-800 cursor-pointer hover:text-gray-600 transition-colors" />
        </div>
      </div>
      
      <!-- =================================================================== -->
      <!-- MOBILE NAVIGATION MENU -->
      <!-- =================================================================== -->
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:hidden lg:mt-0">
        <div class="lg:hidden w-full">
          <div class="bg-white rounded-lg shadow-lg border border-gray-100 mx-4 mt-2">
            <div class="p-4">
              <!-- Mobile navigation grid layout -->
              <div class="grid grid-cols-2 gap-3 mb-4">
                {sortedMenuItems.map((item) => (
                  item.dropdown ? (
                    <!-- Dropdown menu item -->
                    <div class="col-span-2">
                      <details class="group">
                        <summary class="flex items-center justify-between w-full px-4 py-3 text-gray-700 bg-gray-50 rounded-lg cursor-pointer hover:bg-gray-100 transition-colors">
                          <div class="flex items-center gap-3">
                            <Icon name={item.icon} size="sm" class="w-5 h-5 text-gray-600" />
                            <span class="font-medium text-sm">{item.title}</span>
                          </div>
                          <Icon name="chevron" size="sm" class="w-4 h-4 transition-transform duration-200 group-open:rotate-180" />
                        </summary>
                        <!-- Dropdown content -->
                        <div class="mt-2 space-y-1 pl-8">
                          {item.dropdown.items.map((dropdownItem) => (
                            <a
                              href={dropdownItem.path}
                              class="block px-3 py-2 text-sm text-gray-600 hover:text-gray-900 hover:bg-gray-50 rounded transition-colors"
                            >
                              {dropdownItem.title}
                            </a>
                          ))}
                        </div>
                      </details>
                    </div>
                  ) : (
                    <!-- Regular menu item -->
                    <a
                      href={item.path}
                      class="flex flex-col items-center gap-3 p-4 text-gray-700 hover:text-gray-900 hover:bg-gray-50 rounded-lg transition-all duration-200 min-h-[90px] justify-center border border-gray-100 hover:border-gray-200"
                    >
                      <Icon name={item.icon} size="md" class="w-6 h-6 text-gray-600" />
                      <span class="text-xs font-medium text-center leading-tight">{item.title}</span>
                    </a>
                  )
                ))}
              </div>
              
              <!-- Mobile social links section -->
              <div class="pt-3 border-t border-gray-200 space-y-2">
                {sortedSocialLinks.map((social) => (
                  <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`
                      flex items-center justify-center gap-3 w-full px-4 py-3 text-sm font-medium rounded-lg
                      transition-all duration-200 border
                      ${social.color === 'blue'
                        ? 'text-white bg-blue-600 hover:bg-blue-700 border-blue-600 hover:border-blue-700'
                        : 'text-gray-700 bg-gray-50 hover:bg-gray-100 border-gray-200 hover:border-gray-300'
                      }
                    `}
                  >
                    <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                      <path d={socialIcons[social.icon]} />
                    </svg>
                    <span>{social.title}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </MenuItems>
    </Astronav>
    
    <!-- ===================================================================== -->
    <!-- DESKTOP NAVIGATION MENU -->
    <!-- ===================================================================== -->
    <nav class="hidden lg:flex items-center gap-2 desktop-nav">
      <!-- Main navigation items -->
      {sortedMenuItems.map((item) => (
        item.dropdown ? (
          <Dropdown items={item.dropdown.items} trigger={item.title} />
        ) : (
          <Link 
            style={item.style} 
            href={item.path} 
            size="md"
            class="transition-all duration-200 hover:scale-105"
          >
            {item.title}
          </Link>
        )
      ))}
      
      <!-- Desktop social links with separator -->
      <div class="flex items-center gap-4 ml-4 pl-4 border-l border-gray-200">
        {sortedSocialLinks.map((social, index) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`
              inline-flex items-center gap-2 px-4 py-2 text-sm font-medium rounded-lg
              transition-all duration-200 shadow-sm hover:shadow-md transform hover:scale-105
              ${index > 0 ? 'lg:ml-3 xl:ml-3' : ''}
              ${social.color === 'blue'
                ? 'text-white bg-blue-600 border border-blue-600 hover:bg-blue-700 hover:border-blue-700'
                : 'text-gray-700 bg-white border border-gray-300 hover:bg-gray-50 hover:text-gray-900'
              }
              lg:px-2 lg:py-2 xl:px-4 xl:py-2
            `}
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d={socialIcons[social.icon]} />
            </svg>
            <span class="inline">{social.title}</span>
          </a>
        ))}
      </div>
    </nav>
  </header>
</Container>

<style>
  @import url('./styles/navbar.css');
</style>


