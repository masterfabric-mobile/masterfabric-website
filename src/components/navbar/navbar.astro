---
// =============================================================================
// IMPORTS
// =============================================================================
import Container from "@components/layout/container.astro";
import Link from "@components/ui/link.astro";
import Dropdown from "./dropdown.astro";
import { Picture } from "astro:assets";
import Icon from "@components/ui/icon-default.astro";
import SocialIcon from "@components/ui/social-icon.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";
import masterFabricPicture from "assets/masterfabric-logo.svg";
import fs from "fs";
import path from "path";


// =============================================================================
// DATA LOADING & PROCESSING
// =============================================================================
// Load navigation configuration from JSON file
const navigationDataPath = path.join(process.cwd(), "src/data/navigation.json");
const navigationData = JSON.parse(fs.readFileSync(navigationDataPath, "utf-8"));

// Destructure navigation data
const { brand, menuItems, socialLinks, responsive } = navigationData;

// Sort menu items and social links by order
const sortedMenuItems = menuItems.sort((a, b) => a.order - b.order);
const sortedSocialLinks = socialLinks.sort((a, b) => a.order - b.order);

// Get current page path - needed to determine active menu item
const { pathname } = Astro.url;
const currentPath = pathname.endsWith('/') && pathname !== '/' 
  ? pathname.slice(0, -1) 
  : pathname;

// Helper function to check if a menu item corresponds to current page
const isCurrentPage = (itemPath) => {
  const normalizeItemPath = itemPath === '/' ? '/' : itemPath.endsWith('/') ? itemPath.slice(0, -1) : itemPath;
  return normalizeItemPath === currentPath;
};
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-start lg:items-center my-2 lg:my-5">
    <Astronav>
      <!-- =================================================================== -->
      <!-- BRAND SECTION - Logo and Company Info -->
      <!-- =================================================================== -->
      <div class="flex w-full lg:w-auto items-start lg:items-center justify-between py-2 lg:py-0">
        <!-- Brand Link with Logo and Text -->
        <a href="/" class="flex items-start lg:items-center group flex-1 min-w-0 mr-3">
          <!-- Logo with hover animation -->
          <span class="inline-block mr-2 sm:mr-3 transition-transform duration-200 group-hover:scale-110 flex-shrink-0">
            <Picture
              src={masterFabricPicture}
              alt={brand.alt}
              width={50}
              sizes="(max-width: 640px) 32px, (max-width: 1024px) 40px, 50px"
              loading="eager"
              format="avif"
              class="w-8 h-8 sm:w-10 sm:h-10 lg:w-12 lg:h-12"
            />
          </span>
          
          <!-- Brand text and description -->
          <div class="flex flex-col min-w-0 flex-1">
            <!-- Company name with gradient effect -->
            <div class="flex items-baseline flex-wrap">
              <span class="font-bold font-mono text-lg sm:text-xl lg:text-4xl text-slate-800">
                {brand.text.main}
              </span>
              <span class="font-mono text-slate-500 text-lg sm:text-xl lg:text-3xl">
                {brand.text.secondary}
              </span>
              <span class="font-mono text-slate-300 text-lg sm:text-xl lg:text-3xl">
                {brand.text.tertiary}
              </span>
            </div>
            
            <!-- Company tagline -->
            <div class="font-mono text-xs sm:text-sm text-slate-400 mt-1 leading-tight">
              <div class="flex flex-col sm:flex-row sm:gap-1">
                <span class="whitespace-nowrap">{brand.description.platform}</span>
                <span class="font-bold text-slate-500 whitespace-nowrap">{brand.description.studio}</span>
              </div>
            </div>
          </div>
        </a>
        
        <!-- Mobile menu toggle button -->
        <div class="flex lg:hidden flex-shrink-0 items-start pt-1">
          <MenuIcon class="w-7 h-7 text-gray-800 cursor-pointer hover:text-gray-600 transition-colors" />
        </div>
      </div>
      
      <!-- =================================================================== -->
      <!-- MOBILE NAVIGATION MENU -->
      <!-- =================================================================== -->
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:hidden lg:mt-0">
        <div class="lg:hidden w-full">
          <div class="bg-white rounded-lg shadow-lg border border-gray-100 mx-4 mt-2">
            <div class="p-4">
              <!-- Mobile navigation grid layout -->
              <div class="grid grid-cols-2 gap-3 mb-4">
                {sortedMenuItems.map((item) => (
                  item.dropdown ? (
                    <!-- Dropdown menu item -->
                    <div class="col-span-2">
                      <details class="group">
                        <summary class={`flex items-center justify-between w-full px-4 py-3 rounded-lg cursor-pointer transition-colors ${
                          isCurrentPage(item.path) 
                            ? 'bg-blue-50 text-blue-600 mobile-active-item' 
                            : 'text-gray-700 bg-gray-50 hover:bg-gray-100'
                        }`}>
                          <div class="flex items-center gap-3">
                            <Icon name={item.icon} size="sm" class={`w-5 h-5 ${isCurrentPage(item.path) ? 'text-blue-600' : 'text-gray-600'}`} />
                            <span class="font-medium text-sm">{item.title}</span>
                          </div>
                          <Icon name="chevron" size="sm" class="w-4 h-4 transition-transform duration-200 group-open:rotate-180" />
                        </summary>
                        <!-- Dropdown content -->
                        <div class="mt-2 space-y-1 pl-8">
                          {item.dropdown.items.map((dropdownItem) => (
                            <a
                              href={isCurrentPage(dropdownItem.path) ? undefined : dropdownItem.path}
                              class={`block px-3 py-2 text-sm rounded transition-colors ${
                                isCurrentPage(dropdownItem.path) 
                                  ? 'bg-blue-50 text-blue-600 cursor-default border-l-2 border-blue-500' 
                                  : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50'
                              }`}
                              aria-current={isCurrentPage(dropdownItem.path) ? 'page' : undefined}
                            >
                              {dropdownItem.title}
                              {isCurrentPage(dropdownItem.path) && (
                                <span class="ml-2 w-2 h-2 bg-blue-500 rounded-full inline-block"></span>
                              )}
                            </a>
                          ))}
                        </div>
                      </details>
                    </div>
                  ) : (
                    <!-- Regular menu item with active state -->
                    <a
                      href={isCurrentPage(item.path) ? undefined : item.path}
                      class={`flex flex-col items-center gap-3 p-4 rounded-lg transition-all duration-200 min-h-[90px] justify-center ${
                        isCurrentPage(item.path) 
                          ? 'bg-blue-50 text-blue-700 cursor-default mobile-active-item' 
                          : 'text-gray-700 hover:text-gray-900 hover:bg-gray-50'
                      }`}
                      aria-current={isCurrentPage(item.path) ? 'page' : undefined}
                    >
                      <Icon name={item.icon} size="md" class={`w-6 h-6 ${isCurrentPage(item.path) ? 'text-blue-600' : 'text-gray-600'}`} />
                      <span class="text-xs font-medium text-center leading-tight">{item.title}</span>
                      {isCurrentPage(item.path) && (
                        <span class="active-indicator-dot"></span>
                      )}
                    </a>
                  )
                ))}
              </div>
              
              <!-- Mobile social links section -->
              <div class="pt-3 border-t border-gray-200 space-y-2">
                {sortedSocialLinks.map((social) => (
                  <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class={`
                      flex items-center justify-center gap-3 w-full px-4 py-3 text-sm font-medium rounded-lg
                      transition-all duration-200 border
                      ${social.color === 'blue'
                        ? 'text-white bg-blue-600 hover:bg-blue-700 border-blue-600 hover:border-blue-700'
                        : 'text-gray-700 bg-gray-50 hover:bg-gray-100 border-gray-200 hover:border-gray-300'
                      }
                    `}
                  >
                    <SocialIcon name={social.icon} class="w-4 h-4 flex-shrink-0" />
                    <span>{social.title}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </MenuItems>
    </Astronav>
    
    <!-- ===================================================================== -->
    <!-- DESKTOP NAVIGATION MENU -->
    <!-- ===================================================================== -->
    <nav class="hidden lg:flex items-center gap-2 desktop-nav">
      <!-- Main navigation items with active state -->
      {sortedMenuItems.map((item) => (
        item.dropdown ? (
          <Dropdown 
            items={item.dropdown.items} 
            trigger={item.title}
            currentPath={currentPath}
            isActive={isCurrentPage(item.path)}
          />
        ) : (
          <Link 
            style={isCurrentPage(item.path) ? "active" : (item.title === "Jobs" ? "default" : item.style)} 
            href={isCurrentPage(item.path) ? undefined : item.path} 
            size="md"
            class={`transition-all duration-200 ${
              isCurrentPage(item.path) 
                ? 'desktop-active-item pointer-events-none active-page-glow' 
                : 'hover:scale-105'
            } ${item.title === "Jobs" ? "!border-none !shadow-none" : ""}`}
            aria-current={isCurrentPage(item.path) ? 'page' : undefined}
          >
            {item.title}
            {isCurrentPage(item.path) && (
              <span class="ml-1 w-2 h-2 bg-blue-500 rounded-full inline-block active-page-indicator"></span>
            )}
          </Link>
        )
      ))}
      
      <!-- Desktop social links with separator -->
      <div class="flex items-center gap-4 ml-4 pl-4 border-l border-gray-200">
        {sortedSocialLinks.map((social, index) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`
              inline-flex items-center gap-2 rounded-lg
              transition-all duration-200 shadow-sm hover:shadow-md transform hover:scale-105
              ${index > 0 ? 'lg:ml-2 xl:ml-3' : ''}
              ${social.color === 'blue'
                ? 'text-white bg-blue-600 border border-blue-600 hover:bg-blue-700 hover:border-blue-700'
                : 'text-gray-700 bg-white border border-gray-300 hover:bg-gray-50 hover:text-gray-900'
              }
              px-4 py-2 text-sm font-medium
              lg:px-2 lg:py-2 lg:aspect-square
              xl:px-4 xl:py-2 xl:aspect-auto
            `}
          >
            <SocialIcon name={social.icon} class="w-4 h-4" />
            <span class="inline lg:hidden xl:inline">{social.title}</span>
          </a>
        ))}
      </div>
    </nav>
  </header>
</Container>

<style>
  @import url('./styles/navbar.css');
  
  /* Additional active state styles */
  .mobile-active-item {
    position: relative;
    box-shadow: 0 2px 5px rgba(37, 99, 235, 0.1);
  }

  /* Sağ üstte küçük mavi nokta */
  .active-indicator-dot {
    position: absolute;
    top: 10px;
    right: 10px;
    width: 8px;
    height: 8px;
    background: #3b82f6;
    border-radius: 9999px;
    box-shadow: 0 0 4px #3b82f6aa;
    z-index: 2;
    animation: pulse 2s infinite ease-in-out;
  }

  .mobile-active-item .active-indicator-dot {
    /* Mobilde de doğru konumda olsun */
    top: 10px;
    right: 10px;
  }
  
  .mobile-active-item .active-indicator {
    /* Eski stil, artık kullanılmıyor */
    display: none;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 0.6; transform: scale(0.8); }
    50% { opacity: 1; transform: scale(1.2); }
  }
</style>

