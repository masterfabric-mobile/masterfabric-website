---
/**
 * ProjectFlowTimeline.astro
 * 
 * Main project flow timeline component - Converted to modular structure
 * 
 * This component now uses the following sub-components:
 * - TimelineHeader: Header and description section
 * - TimelineCard: Individual phase cards
 * - StatusBar: Dynamic status bar and controls
 * - Notifications: Toast notifications and modal dialogs
 * 
 * Also uses the following modular files:
 * - types.ts: TypeScript interface definitions
 * - timeline-data.json: Static data
 * - styles.css: CSS styles
 * - controller.ts: JavaScript logic
 */

// Import modular components and type definitions
import TimelineHeader from '@components/timeline/TimelineHeader.astro';
import TimelineCard from '@components/timeline/TimelineCard.astro';
import StatusBar from '@components/timeline/StatusBar.astro';
import Notifications from '@components/timeline/Notifications.astro';
import type { TimelineProps } from '@components/timeline/types.ts';

// Import static data from JSON file
import projectFlowData from '../../data/project-flow.json';

// Define prop types
interface Props extends TimelineProps {}

// Use provided timeline or fallback to project-flow data
const { timeline = projectFlowData.timeline } = Astro.props;
---

<!-- 
  Main timeline section - Built using modular components
-->
<section class="project-flow-timeline">
  <!-- Header section -->
  <TimelineHeader timeline={timeline} />

  <!-- Timeline container -->
  <div class="timeline-container">
    <div class="timeline-track">
      {timeline.phases.map((phase) => (
        <TimelineCard phase={phase} />
      ))}
    </div>
  </div>

  <!-- Dynamic status bar -->
  <StatusBar />

  <!-- Notifications -->
  <Notifications />
</section>

<!-- Include CSS styles -->
<link rel="stylesheet" href="/src/components/timeline/styles.css" />

<script define:vars={{ timeline }}>
  // Import timeline controller correctly and initialize
  (async function initializeTimeline() {
    try {
      // Import the controller module
      const { ProjectFlowTimeline } = await import('/src/components/timeline/controller.ts');
      
      // Start timeline after DOM is loaded
      function startTimeline() {
        // Check if status bar elements exist
        const statusBar = document.getElementById('dynamic-status-messages');
        const timelineSection = document.querySelector('.project-flow-timeline');
        
        if (!statusBar || !timelineSection) {
          console.warn('Timeline elements not found, retrying...');
          setTimeout(startTimeline, 100);
          return;
        }

        // Initialize ProjectFlowTimeline class
        const timelineInstance = new ProjectFlowTimeline(timeline);
        
        // Add to window for global access (for debugging)
        window.timelineInstance = timelineInstance;
        
        console.log('Timeline successfully initialized');
      }

      // Start when DOM is ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', startTimeline);
      } else {
        // DOM is already ready
        startTimeline();
      }
    } catch (error) {
      console.error('Error occurred while initializing timeline:', error);
    }
  })();
</script>
