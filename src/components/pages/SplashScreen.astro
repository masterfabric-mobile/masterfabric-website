---
/**
 * Splash Screen Component
 * Shows during app initialization with logo and version only
 */
import { Picture } from "astro:assets";
import masterFabricLogo from "../../assets/masterfabric-logo.svg";
---

<div id="splash-screen" class="splash-screen">
  <div class="splash-container">
    
    <!-- Logo Section -->
    <div class="logo-section">
      <Picture
        src={masterFabricLogo}
        alt="MasterFabric Logo"
        width={120}
        height={95}
        sizes="(max-width: 640px) 80px, (max-width: 1024px) 100px, 120px"
        loading="eager"
        format="avif"
        class="splash-logo"
      />
    </div>

    <!-- Version -->
    <div class="version-section">
      <div class="version-info">v1.0</div>
    </div>
  </div>
</div>

<style>
  .splash-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 1;
    visibility: visible;
    transition: opacity 0.5s ease-out, visibility 0s linear 0s;
  }

  .splash-screen.fade-out {
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease-out, visibility 0s linear 0.5s;
  }

  .splash-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    height: 100vh;
    width: 100%;
    padding: 4rem 2rem;
    box-sizing: border-box;
  }

  /* Logo Section */
  .logo-section {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: fadeIn 0.8s ease-out 0.3s forwards;
  }

  .splash-logo {
    width: 120px;
    height: auto;
    filter: brightness(0) saturate(100%);
  }

  /* Mobile responsive logo */
  @media (max-width: 640px) {
    .splash-logo {
      width: 80px;
    }
  }

  @media (min-width: 1024px) {
    .splash-logo {
      width: 140px;
    }
  }

  /* Version Section */
  .version-section {
    opacity: 0;
    animation: fadeIn 0.5s ease-out 0.8s forwards;
  }

  .version-info {
    color: #000000;
    font-size: 0.875rem;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-weight: 400;
    text-align: center;
  }

  /* Animations */
  @keyframes fadeIn {
    to {
      opacity: 1;
    }
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .splash-screen,
    .logo-section,
    .version-section {
      transition: none;
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  class SplashScreenManager {
splashScreen: HTMLElement | null;
    constructor() {
      this.splashScreen = document.getElementById('splash-screen');
      this.init();
    }

    async init() {
      console.log('Starting app initialization...');
      
      // Wait for minimum display time
      await this.wait(2000);
      
      // Hide splash screen
      this.hideSplashScreen();
    }

    hideSplashScreen() {
      console.log('Hiding splash screen...');
      
      if (this.splashScreen) {
        this.splashScreen.classList.add('fade-out');
        
        // Remove from DOM after transition
        setTimeout(() => {
          if (this.splashScreen && this.splashScreen.parentNode) {
            this.splashScreen.parentNode.removeChild(this.splashScreen);
          }
          
          // Trigger custom event for app ready
          document.dispatchEvent(new CustomEvent('app-ready'));
          console.log('Splash screen removed, app is ready');
        }, 500);
      }
    }

    wait(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }
  }

  // Initialize splash screen when DOM is loaded
  document.addEventListener('DOMContentLoaded', () => {
    new SplashScreenManager();
  });

  // Fallback initialization if DOM is already loaded
  if (document.readyState !== 'loading') {
    new SplashScreenManager();
  }
</script>
