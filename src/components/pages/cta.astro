---
import Link from "@components/ui/link.astro";
---

<div
  class="bg-black py-8 md:px-20 md:py-20 mt-20 mx-auto max-w-5xl rounded-lg flex flex-col items-center text-center">
  <h2 class="text-white text-4xl md:text-6xl tracking-tight">
    Ready to Build Something Great Together?
  </h2>
  <p class="text-slate-400 mt-4 text-lg md:text-xl">
    Contact us today to discuss your project. Whether you have a full plan or just an idea, we’re here to help every step of the way.

  </p>
  <div class="flex mt-5">

    <Link href="/contact" style="inverted">Get Started</Link>
  </div>
</div>
