---
import { Icon } from "astro-icon/components";
import "../../styles/refactor-application.css";
---

<!-- App Enhancement Section -->
<section class="relative py-16 lg:py-24 bg-white overflow-hidden">
  <!-- Subtle geometric background -->
  <div class="absolute inset-0">
    <svg class="absolute top-0 left-0 w-full h-full opacity-[0.02]" viewBox="0 0 100 100" preserveAspectRatio="none">
      <defs>
        <pattern id="triangles" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <polygon points="10,2 18,16 2,16" fill="currentColor"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#triangles)"/>
    </svg>
  </div>
  
  <!-- Floating minimal elements -->
  <div class="absolute top-24 right-16 w-20 h-20 border border-blue-200 rounded-full opacity-30 floating-ring"></div>
  <div class="absolute bottom-32 left-12 w-16 h-16 border border-gray-200 rounded-full opacity-40 floating-ring delay-1"></div>
  <div class="absolute top-1/2 left-1/4 w-12 h-12 border border-blue-200 rounded-full opacity-25 floating-ring delay-2"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header Section - Consistent with codebase patterns -->
    <div class="text-center mb-16">
      <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-gray-900 leading-tight mb-6">
        <span class="block">App Design,</span>
        <span class="block text-blue-600">Optimization</span>
        <span class="block">and Growth</span>
      </h1>
      
      <p class="text-lg lg:text-xl text-gray-600 max-w-3xl mx-auto leading-relaxed">
        Already have an app? We can help refresh its look and enhance its performance. 
        We focus on improving user experience and applying the latest technologies.
      </p>
    </div>

    <!-- Main Content Grid -->
    <div class="grid lg:grid-cols-2 gap-12 xl:gap-16 items-center">
      
      <!-- Services Column -->
      <div class="space-y-8">
        <!-- Services Grid -->
        <div class="grid md:grid-cols-2 gap-6">
          <!-- Event Tracking -->
          <div class="service-card group relative p-8 rounded-2xl border-2 transition-all duration-500 hover:scale-[1.02] cursor-pointer bg-white shadow-sm hover:shadow-xl service-blue">
            <!-- Background Pattern -->
            <div class="absolute top-0 right-0 w-24 h-24 opacity-5 overflow-hidden rounded-tr-2xl">
              <div class="w-full h-full bg-blue-500 transform rotate-45 translate-x-6 -translate-y-6"></div>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-blue-50 border-2 border-blue-100 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
              </svg>
            </div>
            
            <!-- Content -->
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-gray-800 transition-colors">
              Event Tracking
            </h3>
            <p class="text-gray-600 leading-relaxed">
              Track user interactions and behaviors with detailed analytics and insights
            </p>
          </div>

          <!-- Crash Reports & Monitoring -->
          <div class="service-card group relative p-8 rounded-2xl border-2 transition-all duration-500 hover:scale-[1.02] cursor-pointer bg-white shadow-sm hover:shadow-xl service-indigo">
            <!-- Background Pattern -->
            <div class="absolute top-0 right-0 w-24 h-24 opacity-5 overflow-hidden rounded-tr-2xl">
              <div class="w-full h-full bg-indigo-500 transform rotate-45 translate-x-6 -translate-y-6"></div>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-indigo-50 border-2 border-indigo-100 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            
            <!-- Content -->
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-gray-800 transition-colors">
              Crash Reports & Monitoring
            </h3>
            <p class="text-gray-600 leading-relaxed">
              Monitor app stability and identify performance issues in real-time
            </p>
          </div>

          <!-- Analytics Reports -->
          <div class="service-card group relative p-8 rounded-2xl border-2 transition-all duration-500 hover:scale-[1.02] cursor-pointer bg-white shadow-sm hover:shadow-xl service-purple">
            <!-- Background Pattern -->
            <div class="absolute top-0 right-0 w-24 h-24 opacity-5 overflow-hidden rounded-tr-2xl">
              <div class="w-full h-full bg-purple-500 transform rotate-45 translate-x-6 -translate-y-6"></div>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-purple-50 border-2 border-purple-100 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
            </div>
            
            <!-- Content -->
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-gray-800 transition-colors">
              Analytics Reports
            </h3>
            <p class="text-gray-600 leading-relaxed">
              Comprehensive data insights and metrics to drive growth strategies
            </p>
          </div>

          <!-- Release Monitoring -->
          <div class="service-card group relative p-8 rounded-2xl border-2 transition-all duration-500 hover:scale-[1.02] cursor-pointer bg-white shadow-sm hover:shadow-xl service-cyan">
            <!-- Background Pattern -->
            <div class="absolute top-0 right-0 w-24 h-24 opacity-5 overflow-hidden rounded-tr-2xl">
              <div class="w-full h-full bg-cyan-500 transform rotate-45 translate-x-6 -translate-y-6"></div>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-cyan-50 border-2 border-cyan-100 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
            </div>
            
            <!-- Content -->
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-gray-800 transition-colors">
              Release Monitoring
            </h3>
            <p class="text-gray-600 leading-relaxed">
              Track deployment success and monitor issues with real-time alerts
            </p>
          </div>

          <!-- BigData Management -->
          <div class="service-card group relative p-8 rounded-2xl border-2 transition-all duration-500 hover:scale-[1.02] cursor-pointer bg-white shadow-sm hover:shadow-xl service-slate">
            <!-- Background Pattern -->
            <div class="absolute top-0 right-0 w-24 h-24 opacity-5 overflow-hidden rounded-tr-2xl">
              <div class="w-full h-full bg-slate-500 transform rotate-45 translate-x-6 -translate-y-6"></div>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-slate-50 border-2 border-slate-100 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
              </svg>
            </div>
            
            <!-- Content -->
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-gray-800 transition-colors">
              BigData Management
            </h3>
            <p class="text-gray-600 leading-relaxed">
              Process and analyze large datasets to extract meaningful insights
            </p>
          </div>

          <!-- User Growth & Retention -->
          <div class="service-card group relative p-8 rounded-2xl border-2 transition-all duration-500 hover:scale-[1.02] cursor-pointer bg-white shadow-sm hover:shadow-xl service-teal">
            <!-- Background Pattern -->
            <div class="absolute top-0 right-0 w-24 h-24 opacity-5 overflow-hidden rounded-tr-2xl">
              <div class="w-full h-full bg-teal-500 transform rotate-45 translate-x-6 -translate-y-6"></div>
            </div>
            
            <!-- Icon -->
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-teal-50 border-2 border-teal-100 mb-6 group-hover:scale-110 transition-transform duration-300">
              <svg class="w-8 h-8 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            
            <!-- Content -->
            <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-gray-800 transition-colors">
              User Growth & Retention
            </h3>
            <p class="text-gray-600 leading-relaxed">
              Optimize user acquisition and engagement to increase retention rates
            </p>
          </div>
        </div>
      </div>

      <!-- App Showcase Column - Centered -->
      <div class="lg:col-span-1 flex justify-center items-center">
        <div class="sticky top-24">
          <!-- iPhone 16 Pro Max Mockup with Safe Area - More Compact -->
          <div class="relative mx-auto">
            <!-- iPhone Frame - Clean Design - Smaller -->
            <div class="relative bg-gray-900 rounded-[2.5rem] p-2 shadow-2xl phone-frame" style="aspect-ratio: 9/19.5; width: 250px; max-width: 100%;">
              <!-- Dynamic Island - Simplified -->
              <div class="absolute top-3 left-1/2 transform -translate-x-1/2 w-24 h-6 bg-black rounded-full z-30">
                <div class="absolute top-1 left-4 w-3 h-3 bg-gray-800 rounded-full flex items-center justify-center">
                  <div class="w-1.5 h-1.5 bg-gray-600 rounded-full"></div>
                </div>
                <div class="absolute top-1.5 right-4 w-10 h-1.5 bg-gray-800 rounded-full"></div>
              </div>
              <!-- Screen with Safe Areas -->
              <div class="bg-gradient-to-br from-gray-50 via-blue-50/30 to-indigo-50/20 rounded-[2.25rem] overflow-hidden relative h-full phone-screen">
                <!-- App Content -->
                <div class="h-full relative flex flex-col" id="phoneContent">
                  <!-- Top Status - Smaller -->
                  <div class="flex justify-end px-3 pt-2 pb-0">
                    <span class="w-1.5 h-1.5 bg-green-500 rounded-full"></span>
                  </div>
                  
                  <!-- Main Content - Centered Layout - Compressed -->
                  <div class="flex-1 flex flex-col px-3">
                    <!-- Content Area - More Compact -->
                    <div class="flex-1 flex flex-col items-center justify-center space-y-2 py-2">
                      <!-- Performance Card - Smaller -->
                      <div class="bg-blue-50 rounded-lg p-3 text-center border border-blue-100 w-full max-w-[180px] shadow-sm hover:shadow-md transition-all duration-300">
                        <div id="performanceValue" class="text-2xl font-bold text-blue-600 mb-0.5">85%</div>
                        <div class="text-sm font-medium text-gray-800 mb-0.5">App Performance</div>
                        <div class="text-[10px] text-blue-600">↗ +12% this week</div>
                      </div>
                      
                      <!-- Analytics Cards - Smaller -->
                      <div class="grid grid-cols-2 gap-2 w-full max-w-[180px]">
                        <!-- Real-time Analytics - Smaller -->
                        <div class="bg-white rounded-lg p-2 text-center border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300">
                          <div class="text-base font-bold text-gray-900">24.8K</div>
                          <div class="text-[10px] text-gray-500">Active Users</div>
                          <div class="text-[10px] text-green-600">+15.2%</div>
                        </div>
                        <!-- Performance Monitoring - Smaller -->
                        <div class="bg-white rounded-lg p-2 text-center border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300">
                          <div class="text-base font-bold text-gray-900">0.8s</div>
                          <div class="text-[10px] text-gray-500">Load Time</div>
                          <div class="text-[10px] text-green-600">-45%</div>
                        </div>
                        <!-- Crash Detection - Smaller -->
                        <div class="bg-white rounded-lg p-2 text-center border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300">
                          <div class="text-base font-bold text-gray-900">99.2%</div>
                          <div class="text-[10px] text-gray-500">Stability</div>
                          <div class="text-[10px] text-green-600">+2.4%</div>
                        </div>
                        <!-- User Engagement - Smaller -->
                        <div class="bg-white rounded-lg p-2 text-center border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300">
                          <div class="text-base font-bold text-gray-900">4.9</div>
                          <div class="text-[10px] text-gray-500">Rating</div>
                          <div class="text-[10px] text-green-600">+0.2</div>
                        </div>
                      </div>
                      
                      <!-- Features Section - More Compact -->
                      <div class="w-full max-w-[180px] bg-white rounded-lg p-2 border border-gray-100 shadow-sm hover:shadow-md transition-all duration-300">
                        <div class="text-xs font-semibold text-gray-800 mb-1">Features</div>
                        
                        <!-- Feature Items - More Compact -->
                        <div class="space-y-1">
                          <!-- Feature 1 -->
                          <div class="feature-item flex items-center space-x-1.5 opacity-0 animate-feature" style="animation-delay: 0ms;">
                            <div class="w-1.5 h-1.5 bg-blue-500 rounded-full"></div>
                            <span class="text-[10px] text-gray-700">Real-time Analytics</span>
                          </div>
                          
                          <!-- Feature 2 -->
                          <div class="feature-item flex items-center space-x-1.5 opacity-0 animate-feature" style="animation-delay: 200ms;">
                            <div class="w-1.5 h-1.5 bg-purple-500 rounded-full"></div>
                            <span class="text-[10px] text-gray-700">Crash Detection</span>
                          </div>
                          
                          <!-- Feature 3 -->
                          <div class="feature-item flex items-center space-x-1.5 opacity-0 animate-feature" style="animation-delay: 400ms;">
                            <div class="w-1.5 h-1.5 bg-green-500 rounded-full"></div>
                            <span class="text-[10px] text-gray-700">Performance Monitor</span>
                          </div>
                          
                          <!-- Feature 4 -->
                          <div class="feature-item flex items-center space-x-1.5 opacity-0 animate-feature" style="animation-delay: 600ms;">
                            <div class="w-1.5 h-1.5 bg-yellow-500 rounded-full"></div>
                            <span class="text-[10px] text-gray-700">User Engagement</span>
                          </div>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Fixed Button Placement - Smaller and attached to bottom -->
                    <div class=" rounded-b-lg border-b border-x border-gray-100 p-3 mt-auto">
                      <button id="optimizeBtn" class="w-full bg-blue-600 hover:bg-blue-700 text-white rounded-lg py-2 font-semibold text-xs transition-all duration-200 shadow-md">
                        Optimize Now
                      </button>
                    </div>
                  </div>
                  
                  <!-- Fixed Popup Visibility -->
                  <div id="optimizationPopup" class="absolute inset-0 flex items-center justify-center z-50 opacity-0 pointer-events-none transition-all duration-300 transform scale-95">
                    <!-- Background Overlay - Fixed opacity -->
                    <div class="absolute inset-0 bg-gray-900/70 backdrop-blur-sm"></div>
                    
                    <!-- Popup Content - Smaller -->
                    <div class="relative bg-white rounded-xl p-4 mx-3 w-full max-w-[200px] border border-gray-100 popup-content" style="box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
                      
                      <!-- Header - Smaller -->
                      <div class="text-center mb-3">
                        <!-- Animated Optimization Icon -->
                        <div class="w-8 h-8 mx-auto mb-2 relative">
                          <!-- Rotating Gear Icon -->
                          <div class="absolute inset-0 text-blue-600 optimization-gear-icon">
                            <svg class="w-full h-full animate-spin" style="animation-duration: 2s;" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
                            </svg>
                          </div>
                          <!-- Pulsing Effect -->
                          <div class="absolute inset-0 bg-blue-500/20 rounded-full animate-ping"></div>
                          <!-- Static Center Dot -->
                          <div class="absolute inset-0 flex items-center justify-center">
                            <div class="w-1 h-1 bg-blue-600 rounded-full"></div>
                          </div>
                        </div>
                        
                        <h3 class="text-base font-bold text-gray-900 mb-1">Optimizing Your App</h3>
                        <p class="text-xs text-gray-600">Enhancing app performance</p>
                      </div>
                      
                      <!-- Progress Bar - Smaller -->
                      <div class="mb-3">
                        <div class="flex justify-between items-center mb-1">
                          <span id="progressText" class="text-xs font-medium text-gray-700">Analyzing...</span>
                          <span id="progressPercentage" class="text-xs text-gray-500">0%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-1.5">
                          <div id="progressBar" class="bg-blue-600 h-1.5 rounded-full transition-all duration-500 ease-out" style="width: 0%"></div>
                        </div>
                      </div>
                      
                      <!-- Step Indicators - Smaller -->
                      <div class="space-y-2 mb-4">
                        <!-- Step 1: Analyzing -->
                        <div id="step1" class="flex items-center space-x-2 step-indicator">
                          <div class="step-icon w-4 h-4 rounded-full border-2 border-gray-300 flex items-center justify-center transition-all duration-300">
                            <div class="w-2 h-2 bg-gray-300 rounded-full step-dot transition-all duration-300"></div>
                          </div>
                          <span class="text-xs text-gray-600 transition-colors duration-300">Analyzing Performance</span>
                        </div>
                        
                        <!-- Step 2: Optimizing -->
                        <div id="step2" class="flex items-center space-x-2 step-indicator">
                          <div class="step-icon w-4 h-4 rounded-full border-2 border-gray-300 flex items-center justify-center transition-all duration-300">
                            <div class="w-2 h-2 bg-gray-300 rounded-full step-dot transition-all duration-300"></div>
                          </div>
                          <span class="text-xs text-gray-600 transition-colors duration-300">Optimizing Code</span>
                        </div>
                        
                        <!-- Step 3: Applying -->
                        <div id="step3" class="flex items-center space-x-2 step-indicator">
                          <div class="step-icon w-4 h-4 rounded-full border-2 border-gray-300 flex items-center justify-center transition-all duration-300">
                            <div class="w-2 h-2 bg-gray-300 rounded-full step-dot transition-all duration-300"></div>
                          </div>
                          <span class="text-xs text-gray-600 transition-colors duration-300">Applying Changes</span>
                        </div>
                      </div>
                      
                      <!-- Loading Animation - Smaller -->
                      <div id="loadingAnimation" class="flex justify-center mb-3">
                        <div class="flex space-x-1">
                          <div class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce loading-dot"></div>
                          <div class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce loading-dot" style="animation-delay: 0.1s;"></div>
                          <div class="w-1.5 h-1.5 bg-blue-600 rounded-full animate-bounce loading-dot" style="animation-delay: 0.2s;"></div>
                        </div>
                      </div>
                      
                      <!-- Cancel Button - Smaller -->
                      <button id="cancelOptimization" class="w-full bg-gray-100 text-gray-700 font-medium py-2 rounded-lg text-xs hover:bg-gray-200 transition-colors">
                        Cancel
                      </button>
                    </div>
                  </div>
                  
                  <!-- Success Popup - Smaller -->
                  <div id="successPopup" class="absolute inset-0 flex items-center justify-center z-50 opacity-0 pointer-events-none transition-all duration-300 transform scale-95">
                    <!-- Background Overlay - Fixed opacity -->
                    <div class="absolute inset-0 bg-gray-900/70 backdrop-blur-sm"></div>
                    
                    <!-- Popup Content - Smaller -->
                    <div class="relative bg-white rounded-xl p-4 mx-3 w-full max-w-[200px] border border-gray-100" style="box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
                      <!-- Success Animation Icon with Gear - Smaller -->
                      <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-3 success-icon relative">
                        <!-- Animated Success Gear Icon -->
                        <div class="w-10 h-10 bg-green-500 rounded-full flex items-center justify-center relative">
                          <!-- Rotating Gear -->
                          <div class="absolute inset-0 text-white success-gear-icon">
                            <svg class="w-6 h-6 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2" fill="currentColor" viewBox="0 0 20 20">
                              <path fill-rule="evenodd" d="M11.49 3.17c-.38-1.56-2.6-1.56-2.98 0a1.532 1.532 0 01-2.286.948c-1.372-.836-2.942.734-2.106 2.106.54.886.061 2.042-.947 2.287-1.561.379-1.561 2.6 0 2.978a1.532 1.532 0 01.947 2.287c-.836 1.372.734 2.942 2.106 2.106a1.532 1.532 0 012.287.947c.379 1.561 2.6 1.561 2.978 0a1.533 1.533 0 012.287-.947c1.372.836 2.942-.734 2.106-2.106a1.533 1.533 0 01.947-2.287c1.561-.379 1.561-2.6 0-2.978a1.532 1.532 0 01-.947-2.287c.836-1.372-.734-2.942-2.106-2.106a1.532 1.532 0 01-2.287-.947zM10 13a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd"/>
