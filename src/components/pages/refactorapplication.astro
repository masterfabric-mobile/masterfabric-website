<script>
/**
 * Enhanced Phone Interface with Stepper Optimization
 * Handles optimization flow with 3-step stepper and progress tracking
 */

console.log('🚀 Enhanced Phone Interface with Stepper Optimization Loaded');

/**
 * Popup Fixer - Forces popups to appear if they're not showing up properly
 */
function forceShowPopup(popupId) {
  const popup = document.getElementById(popupId);
  
  if (popup) {
    // First try normal show class
    popup.classList.add('show');
    
    // Then apply direct styles for maximum reliability
    popup.style.cssText = 'display: flex !important; opacity: 1 !important; visibility: visible !important; transform: scale(1) !important; pointer-events: all !important; z-index: 9999 !important;';
    
    console.log(`Forced ${popupId} to show`);
    return true;
  }
  console.error(`Popup with ID ${popupId} not found`);
  return false;
}

// Specific function for optimization popup
function showOptimizationPopup() {
  const popup = document.getElementById('optimizationPopup');
  if (popup) {
    // Reset any existing styles first
    popup.style.cssText = '';
    
    // Force display first (important for some browsers)
    popup.style.display = 'flex';
    
    // Force browser reflow
    void popup.offsetWidth;
    
    // Apply all required styles
    popup.style.opacity = '1';
    popup.style.pointerEvents = 'auto';
    popup.style.transform = 'scale(1)';
    popup.style.visibility = 'visible';
    
    console.log('Optimization popup forced to show');
    return true;
  }
  return false;
}

// Special handler for optimize button
function setupOptimizeButtonHandler() {
  const optimizeBtn = document.getElementById('optimizeBtn');
  if (optimizeBtn) {
    optimizeBtn.addEventListener('click', function(e) {
      console.log('🚀 Optimize button clicked via popupFixer');
      showOptimizationPopup();
      e.stopPropagation();
    });
    return true;
  }
  return false;
}

class EnhancedPhoneInterface {
  constructor() {
    this.isOptimizing = false;
    this.currentStep = 0;
    this.initialPerformanceValue = 0;
    this.optimizationSteps = [
      { 
        id: 'step1', 
        text: 'Analyzing Performance...', 
        duration: 2000,
        description: 'Scanning your app for performance bottlenecks'
      },
      { 
        id: 'step2', 
        text: 'Optimizing Code...', 
        duration: 2500,
        description: 'Applying optimization algorithms'
      },
      { 
        id: 'step3', 
        text: 'Applying Changes...', 
        duration: 1500,
        description: 'Finalizing performance improvements'
      }
    ];
    this.initializeApp();
  }

  initializeApp() {
    console.log('🚀 Initializing Enhanced Phone Interface...');
    this.setRandomPerformanceValue();
    this.setupInteractions();
    this.initializeAnimations();
    this.animateFeatures();
    console.log('✅ Enhanced Phone Interface initialized successfully');
  }
  
  // Add new method to animate features
  animateFeatures() {
    const featureItems = document.querySelectorAll('.feature-item');
    
    // Initial animation on load
    featureItems.forEach(item => {
      item.classList.add('animate-feature');
    });
    
    // Setup recurring animation every 8 seconds
    setInterval(() => {
      featureItems.forEach((item, index) => {
        item.style.opacity = '0';
        
        // Reset animation by removing and adding the class
        setTimeout(() => {
          item.classList.remove('animate-feature');
          // Force reflow
          void item.offsetWidth;
          item.classList.add('animate-feature');
        }, index * 100);
      });
    }, 8000);
  }

  setRandomPerformanceValue() {
    // Set initial random value between 80-90%
    this.initialPerformanceValue = Math.floor(Math.random() * (90 - 80 + 1)) + 80;
    const performanceElement = document.getElementById('performanceValue');
    if (performanceElement) {
      performanceElement.textContent = `${this.initialPerformanceValue}%`;
      console.log(`🔢 Initial performance value set to: ${this.initialPerformanceValue}%`);
    }
  }

  setupInteractions() {
    console.log('🔧 Setting up interactions...');
    
    // Setup optimize button click handler
    const optimizeBtn = document.getElementById('optimizeBtn');
    console.log('🔍 Optimize button found:', !!optimizeBtn);
    
    if (optimizeBtn) {
      console.log('✅ Adding click event listener to optimize button');
      // Clear any previous event listeners to avoid duplicates
      optimizeBtn.removeEventListener('click', this._handleOptimizeClick);
      
      // Define the handler and store it as an instance property
      this._handleOptimizeClick = (e) => {
        e.preventDefault();
        e.stopPropagation();
        console.log('🎯 Optimize button clicked!');
        // Use the popup fixer first to ensure visibility
        showOptimizationPopup();
        
        if (!this.isOptimizing) {
          this.startStepperOptimization();
        } else {
          console.log('⚠️ Already optimizing, ignoring click');
        }
      };
      
      // Add the click event listener
      optimizeBtn.addEventListener('click', this._handleOptimizeClick);
    } else {
      console.error('❌ Optimize button not found!');
    }

    // Setup stepper popup close handlers
    const cancelBtn = document.getElementById('cancelOptimization');
    
    if (cancelBtn) {
      cancelBtn.addEventListener('click', (e) => {
        e.preventDefault();
        this.cancelOptimization();
      });
    }

    // Setup success popup close handlers
    const closePopup = document.getElementById('closePopup');
    
    if (closePopup) {
      closePopup.addEventListener('click', (e) => {
        e.preventDefault();
        this.hideSuccessPopup();
      });
    }
  }

  async startStepperOptimization() {
    console.log('🎬 Starting stepper optimization...');
    if (this.isOptimizing) {
      console.log('⚠️ Already optimizing, ignoring click');
      return;
    }
    
    this.isOptimizing = true;
    this.currentStep = 0;
    
    try {
      // Reset and prepare UI
      this.resetOptimizationUI();
      
      // Show optimization popup
      this.showOptimizationPopup();
      await this.wait(500); // Give the popup time to appear
      
      // Execute optimization steps one by one
      for (let i = 0; i < this.optimizationSteps.length; i++) {
        const step = this.optimizationSteps[i];
        
        console.log(`🔄 Starting step ${i+1}: ${step.text}`);
        
        // Activate current step indicator
        this.activateStep(step.id);
        this.updateProgressText(step.text);
        
        // Run progress animation from 0 to 100% for each step separately
        await this.animateProgress(0, 100);
        
        // Wait for specified duration
        await this.wait(step.duration);
        
        // Mark step as complete
        this.completeStep(step.id);
        console.log(`✅ Completed step ${i+1}: ${step.text}`);
        
        // Transition effect between steps
        if (i < this.optimizationSteps.length - 1) {
          await this.transitionToNextStep();
        }
        
        this.currentStep++;
      }
      
      console.log('✅ All optimization steps completed successfully!');
      
      // Show success popup after completion
      await this.wait(500);
      this.hideOptimizationPopup();
      await this.wait(300);
      this.improvePerformanceValue();
      this.showSuccessPopup();
    } catch (error) {
      console.error('❌ Error during optimization:', error);
      this.cancelOptimization();
    } finally {
      this.isOptimizing = false;
    }
  }
  
  async transitionToNextStep() {
    // Visual effect between steps
    const progressBar = document.getElementById('progressBar');
    if (progressBar) {
      // Add pulsing effect
      progressBar.classList.add('pulse-effect');
      await this.wait(300);
      progressBar.classList.remove('pulse-effect');
      
      // Reset progress bar for next step with a quick animation
      progressBar.style.transition = 'width 0.3s ease-out';
      progressBar.style.width = '0%';
      await this.wait(300);
      progressBar.style.transition = 'width 1s ease-out';
    }
    
    // Update percentage text
    const progressPercentage = document.getElementById('progressPercentage');
    if (progressPercentage) {
      progressPercentage.textContent = '0%';
    }
  }
  
  resetOptimizationUI() {
    // Reset progress bar
    const progressBar = document.getElementById('progressBar');
    const progressPercentage = document.getElementById('progressPercentage');
    if (progressBar) {
      progressBar.style.width = '0%';
      progressBar.style.transition = 'width 1s ease-out';
    }
    if (progressPercentage) progressPercentage.textContent = '0%';
    
    // Reset all steps to initial state
    this.optimizationSteps.forEach(step => {
      const stepElement = document.getElementById(step.id);
      if (stepElement) {
        const icon = stepElement.querySelector('.step-icon');
        const dot = stepElement.querySelector('.step-dot');
        const text = stepElement.querySelector('span');
        
        if (icon) {
          icon.style.borderColor = '#d1d5db';
          icon.style.backgroundColor = 'transparent';
          icon.innerHTML = '<div class="w-2 h-2 bg-gray-300 rounded-full step-dot"></div>';
        }
        if (text) text.style.color = '#6b7280';
      }
    });
    
    // Reset progress text
    this.updateProgressText('Starting optimization...');
  }

  activateStep(stepId) {
    console.log(`🔵 Activating step: ${stepId}`);
    const step = document.getElementById(stepId);
    if (!step) {
      console.error(`❌ Step element not found: ${stepId}`);
      return;
    }
    
    const icon = step.querySelector('.step-icon');
    const dot = step.querySelector('.step-dot');
    const text = step.querySelector('span');
    
    if (icon) icon.style.borderColor = '#3b82f6';
    if (dot) dot.style.backgroundColor = '#3b82f6';
    if (text) text.style.color = '#3b82f6';
  }

  completeStep(stepId) {
    console.log(`✅ Marking step complete: ${stepId}`);
    const step = document.getElementById(stepId);
    if (!step) {
      console.error(`❌ Step element not found: ${stepId}`);
      return;
    }
    
    const icon = step.querySelector('.step-icon');
    const text = step.querySelector('span');
    
    if (icon) {
      icon.style.borderColor = '#10b981';
      icon.style.backgroundColor = '#10b981';
      // Use appropriate SVG size for small circles
      icon.innerHTML = '<svg class="w-2 h-2 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>';
    }
    if (text) text.style.color = '#10b981';
  }

  updateProgressText(text) {
    const progressText = document.getElementById('progressText');
    if (progressText) {
      progressText.textContent = text;
    }
  }

  async animateProgress(startPercent, targetPercent) {
    return new Promise((resolve) => {
      const progressBar = document.getElementById('progressBar');
      const progressPercentage = document.getElementById('progressPercentage');
      
      if (!progressBar || !progressPercentage) {
        console.error('❌ Progress elements not found');
        resolve();
        return;
      }
      
      const duration = 1500; // ms - longer animation for better effect
      const steps = 60;
      const stepSize = (targetPercent - startPercent) / steps;
      const stepDuration = duration / steps;
      
      let currentStep = 0;
      
      const animate = () => {
        currentStep++;
        const percent = Math.min(startPercent + (stepSize * currentStep), targetPercent);
        progressBar.style.width = `${percent}%`;
        progressPercentage.textContent = `${Math.round(percent)}%`;
        
        if (currentStep >= steps) {
          resolve();
        } else {
          setTimeout(animate, stepDuration);
        }
      };
      
      animate();
    });
  }

  improvePerformanceValue() {
    // Increase performance value to 93-98% after optimization
    const newPerformance = Math.floor(Math.random() * (98 - 93 + 1)) + 93;
    const improvement = newPerformance - this.initialPerformanceValue;
    
    const performanceElement = document.getElementById('performanceValue');
    const performanceImprovement = document.getElementById('performanceImprovement');
    
    if (performanceElement) {
      performanceElement.textContent = `${newPerformance}%`;
      console.log(`🚀 Performance improved to: ${newPerformance}% (${improvement > 0 ? '+' : ''}${improvement}%)`);
    }
    
    if (performanceImprovement) {
      performanceImprovement.textContent = `+${improvement}%`;
    }
  }

  animatePerformanceImprovement() {
    const performanceElement = document.getElementById('performanceImprovement');
    if (!performanceElement) return;
    
    const initialValue = this.initialPerformanceValue;
    const newPerformance = parseInt(document.getElementById('performanceValue').textContent);
    const improvement = newPerformance - initialValue;
    
    // Animate from initial improvement value up to actual improvement
    const startValue = Math.floor(improvement * 0.6);
    const endValue = improvement;
    const steps = 5;
    let currentStep = 0;
    
    const interval = setInterval(() => {
      const progress = currentStep / steps;
      const currentValue = Math.round(startValue + (endValue - startValue) * progress);
      
      performanceElement.textContent = `+${currentValue}%`;
      currentStep++;
      
      if (currentStep > steps) {
        clearInterval(interval);
      }
    }, 150);
  }

  cancelOptimization() {
    this.hideOptimizationPopup();
    this.isOptimizing = false;
    this.currentStep = 0;
    
    // Reset progress
    this.resetOptimizationUI();
  }

  initializeAnimations() {
    // Animate in the mobile cards with stagger effect using custom CSS animations
    const mobileCards = document.querySelectorAll('.max-w-\\[180px\\]');
    mobileCards.forEach((card, index) => {
      card.style.animationDelay = `${index * 0.2}s`;
      card.classList.add('mobile-card-enter');
    });
  }

  showOptimizationPopup() {
    console.log('📱 Showing optimization popup');
    // Use the popup fixer for better reliability
    showOptimizationPopup();
  }

  hideOptimizationPopup() {
    const popup = document.getElementById('optimizationPopup');
    if (popup) {
      // First make it invisible but keep it in flow
      popup.style.opacity = '0';
      popup.style.pointerEvents = 'none';
      popup.style.transform = 'scale(0.95)';
      
      // Then after animation completes, hide it
      setTimeout(() => {
        popup.style.display = 'none';
      }, 300);
    }
  }

  showSuccessPopup() {
    console.log('📱 Showing success popup');
    const popup = document.getElementById('successPopup');
    if (popup) {
      // Same reliable approach as optimization popup
      popup.style.display = 'flex';
      
      // Force browser reflow
      void popup.offsetWidth;
      
      // Now make it visible with animation
      popup.style.opacity = '1';
      popup.style.pointerEvents = 'auto';
      popup.style.transform = 'scale(1)';
      
      // Add shine effect to title
      const title = popup.querySelector('h3');
      if (title) title.classList.add('shine-text');
      
      // Animate performance improvements
      this.animatePerformanceImprovement();
    } else {
      console.error('❌ Success popup not found!');
    }
  }

  hideSuccessPopup() {
    const popup = document.getElementById('successPopup');
    if (popup) {
      popup.style.opacity = '0';
      popup.style.pointerEvents = 'none';
      popup.style.transform = 'scale(0.95)';
      
      // Hide the popup after transition completes
      setTimeout(() => {
        popup.style.display = 'none';
      }, 300);
    }
  }

  wait(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }
}

// Initialize when DOM is fully loaded
document.addEventListener('DOMContentLoaded', () => {
  console.log('🌟 DOM Content Loaded - Setting up popups');
  
  // Setup the optimize button handler first
  setupOptimizeButtonHandler();
  
  // Let's ensure that both popups are properly initialized
  const optimizationPopup = document.getElementById('optimizationPopup');
  const successPopup = document.getElementById('successPopup');
  
  console.log('📊 Found popups:', {
    optimization: !!optimizationPopup,
    success: !!successPopup
  });
  
  // IMPROVED OPTIMIZATION POPUP INITIALIZATION
  if (optimizationPopup) {
    // Just make it invisible initially, but keep it in the DOM flow
    optimizationPopup.style.opacity = '0';
    optimizationPopup.style.pointerEvents = 'none';
    optimizationPopup.style.transform = 'scale(0.95)';
    // Don't set display:none initially to prevent layout shifts
    console.log('✅ Initialized optimization popup');
  }
  
  // Success popup can stay hidden until needed
  if (successPopup) {
    successPopup.style.opacity = '0';
    successPopup.style.pointerEvents = 'none';
    successPopup.style.transform = 'scale(0.95)';
    successPopup.style.display = 'none';
    console.log('✅ Initialized success popup');
  }
  
  // Initialize the app interface
  try {
    window.phoneInterface = new EnhancedPhoneInterface();
    
    // Test popup function
    window.testPopupFixer = function() {
      console.log('Running popup fixer test');
      const optimizeBtn = document.getElementById('optimizeBtn');
      if (optimizeBtn) {
        console.log('Found optimize button, simulating click');
        optimizeBtn.click();
      } else {
        console.log('Optimize button not found, trying direct popup show');
        showOptimizationPopup();
      }
      return 'Test complete';
    };
    
  } catch (error) {
