---
import { Icon } from "astro-icon/components";
---

<main class="grid lg:grid-cols-2 place-items-center pt-10 pb-8 md:pt-8 md:pb-12">
  <!-- Content Section -->
  <div class="md:order-1">
    <h2 class="text-xl lg:text-3xl xl:text-5xl font-bold lg:tracking-tight xl:tracking-tighter">
      Custom Mobile App Development 
    </h2>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      Take your business to the next level in the mobile world! Reach your customers anytime, anywhere with custom, user-friendly, and innovative mobile apps tailored to your needs.
    </p>
    <div class="mt-4">
      <div class="flex gap-8 md:gap-20 items-center mt-10 flex-wrap justify-start">
        <Icon class="size-8 md:size-12 hover:text-blue-700" name="simple-icons:ios" />
        <Icon class="size-8 md:size-12 hover:text-blue-700" name="simple-icons:android" />
        <Icon class="size-8 md:size-12 hover:text-blue-700" name="simple-icons:harmonyos" />
      </div>
    </div>
  </div>

  <!-- Animated Code Editor -->
  <div class="py-6 md:order-2 md:block w-full max-w-2xl">
    <div class="code-editor-container">
      <!-- Editor Header -->
      <div class="editor-header">
        <div class="editor-controls">
          <div class="control-dot red"></div>
          <div class="control-dot yellow"></div>
          <div class="control-dot green"></div>
        </div>
        <div class="editor-title" id="editor-title">auth_service.dart</div>
        <div class="editor-actions">
          <div class="action-buttons">
            <button class="action-btn" id="firebase-btn" data-scenario="firebase" title="Firebase Authentication">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L22 9L20 20H4L2 9L12 2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <path d="M12 2V20" stroke="currentColor" stroke-width="2"/>
              </svg>
            </button>
            <button class="action-btn" id="devops-btn" data-scenario="devops" title="DevOps Deployment">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L2 7L12 12L22 7L12 2Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <path d="M2 17L12 22L22 17" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <path d="M2 12L12 17L22 12" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="action-btn" id="splash-btn" data-scenario="splash" title="Splash Screen Logic">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2Z" stroke="currentColor" stroke-width="2"/>
                <path d="M12 8V16" stroke="currentColor" stroke-width="2"/>
                <path d="M8 12H16" stroke="currentColor" stroke-width="2"/>
              </svg>
            </button>
          </div>
          <button class="refresh-btn" id="refresh-btn" title="Restart Animation">
            <svg class="refresh-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 4V10H7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M23 20V14H17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10M23 14L18.36 18.36A9 9 0 0 1 3.51 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>
      </div>
      
      <!-- Editor Content -->
      <div class="editor-content">
        <div class="line-numbers">
          <span>1</span>
          <span>2</span>
          <span>3</span>
          <span>4</span>
          <span>5</span>
          <span>6</span>
          <span>7</span>
          <span>8</span>
          <span>9</span>
          <span>10</span>
          <span>11</span>
          <span>12</span>
          <span>13</span>
          <span>14</span>
          <span>15</span>
          <span>16</span>
        </div>
        
        <div class="code-content">
          <div class="code-line">
            <span class="keyword">import</span> <span class="string">'package:firebase_auth/firebase_auth.dart'</span>;
          </div>
          <div class="code-line">
            <span class="keyword">import</span> <span class="string">'package:cloud_firestore/cloud_firestore.dart'</span>;
          </div>
          <div class="code-line">
          </div>
          <div class="code-line">
            <span class="keyword">class</span> <span class="class">AuthService</span> {
          </div>
          <div class="code-line" id="line-5">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-6">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-7">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-8">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-9">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-10">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-11">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-12">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-13">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-14">
            <span class="indent">  </span>
          </div>
          <div class="code-line" id="line-15">
            <span class="indent">  </span>
          </div>
          <div class="code-line">}</div>
        </div>
      </div>
      
      <!-- Console -->
      <div class="editor-console">
        <div class="console-header">Console Output</div>
        <div class="console-content">
          <div class="console-message" id="console-output"></div>
        </div>
      </div>
      
      <!-- Status Footer -->
      <div class="editor-footer">
        <div class="status-indicator">
          <div class="status-dot" id="status-dot"></div>
          <span class="status-text" id="status-text">Ready</span>
        </div>
      </div>
      
      <!-- Success Overlay -->
      <div class="success-overlay" id="success-overlay">
        <div class="success-content">
          <div class="success-icon-container">
            <svg class="success-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="12" cy="12" r="10" fill="#27ca3f"/>
              <path d="M9 12l2 2 4-4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 id="success-title">Authentication Service Ready!</h3>
          <p id="success-description">Firebase integration completed successfully</p>
          <div class="deploy-btn-container">
            <button class="deploy-btn" id="deploy-btn">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2L22 9L20 20H4L2 9L12 2Z" stroke="currentColor" stroke-width="2"/>
                <path d="M12 2V20" stroke="currentColor" stroke-width="2"/>
              </svg>
              Deploy Your Code
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<style>
.code-editor-container {
  background: #1e1e1e;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  position: relative;
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
  font-size: 13px;
  margin: 0 auto;
}

.editor-header {
  background: #2d2d2d;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid #404040;
}

.editor-controls {
  display: flex;
  gap: 8px;
}

.control-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
}

.control-dot.red { background: #ff5f56; }
.control-dot.yellow { background: #ffbd2e; }
.control-dot.green { background: #27ca3f; }

.editor-title {
  color: #cccccc;
  font-weight: 500;
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
}

.editor-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.action-buttons {
  display: flex;
  gap: 4px;
}

.action-btn {
  background: transparent;
  border: none;
  color: #888;
  cursor: pointer;
  padding: 6px;
  border-radius: 4px;
  transition: all 0.2s ease;
  width: 28px;
  height: 28px;
}

.action-btn:hover {
  color: #cccccc;
  background: #404040;
}

.action-btn.active {
  color: #569cd6;
  background: #1e3a8a20;
}

.action-btn svg {
  width: 16px;
  height: 16px;
}

.refresh-btn {
  background: transparent;
  border: none;
  color: #888;
  cursor: pointer;
  padding: 4px;
  border-radius: 4px;
  transition: all 0.2s ease;
}

.refresh-btn:hover {
  color: #cccccc;
  background: #404040;
}

.refresh-icon {
  width: 16px;
  height: 16px;
  transition: transform 0.3s ease;
}

.refresh-btn:hover .refresh-icon {
  transform: rotate(180deg);
}

.editor-content {
  display: flex;
  background: #1e1e1e;
  min-height: 350px;
}

.line-numbers {
  background: #252526;
  color: #858585;
  padding: 16px 12px;
  text-align: right;
  border-right: 1px solid #404040;
  user-select: none;
  min-width: 50px;
}

.line-numbers span {
  display: block;
  line-height: 1.5;
}

.code-content {
  flex: 1;
  padding: 16px;
  color: #d4d4d4;
  line-height: 1.5;
}

.code-line {
  min-height: 19.5px;
  position: relative;
}

.keyword { color: #569cd6; }
.function { color: #dcdcaa; }
.string { color: #ce9178; }
.comment { color: #6a9955; }
.variable { color: #9cdcfe; }
.class { color: #4ec9b0; }
.number { color: #b5cea8; }
.error { color: #f44747; text-decoration: underline wavy; }
.indent { display: inline-block; width: 2ch; }

.typing-cursor {
  display: none;
}

.editor-console {
  background: #252526;
  border-top: 1px solid #404040;
}

.console-header {
  padding: 8px 16px;
  background: #2d2d2d;
  color: #cccccc;
  font-size: 12px;
  font-weight: 500;
}

.console-content {
  padding: 12px 16px;
  min-height: 60px;
  max-height: 120px;
  overflow-y: auto;
  font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
}

.console-message {
  color: #cccccc;
  font-size: 12px;
  line-height: 1.4;
}

.error-message {
  color: #f44747;
}

.success-message {
  color: #4ec9b0;
}

.info-message {
  color: #569cd6;
}

.success-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(30, 30, 30, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.5s ease;
}

.success-overlay.show {
  opacity: 1;
  visibility: visible;
}

.success-content {
  text-align: center;
  color: #ffffff;
}

.success-icon-container {
  display: flex;
  justify-content: center;
  margin-bottom: 16px;
}

.success-icon {
  width: 64px;
  height: 64px;
  animation: checkmark-pop 0.6s ease-out;
}

.success-content h3 {
  font-size: 24px;
  margin-bottom: 8px;
  color: #27ca3f;
}

.success-content p {
  color: #cccccc;
}

.deploy-btn-container {
  display: flex;
  justify-content: center;
  width: 100%;
}

.deploy-btn {
  margin-top: 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  padding: 12px 24px;
  border-radius: 8px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  transition: all 0.3s ease;
}

.deploy-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
}

.deploy-btn svg {
  width: 20px;
  height: 20px;
}

.editor-footer {
  background: #2d2d2d;
  padding: 8px 16px;
  border-top: 1px solid #404040;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.status-indicator {
  display: flex;
  align-items: center;
  gap: 8px;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #888;
  transition: all 0.3s ease;
}

.status-dot.coding {
  background: #ffbd2e;
  animation: pulse 1.5s infinite;
}

.status-dot.success {
  background: #27ca3f;
}

.status-text {
  color: #cccccc;
  font-size: 12px;
}

@keyframes blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

@keyframes pulse {
  0% { opacity: 1; }
  50% { opacity: 0.5; }
  100% { opacity: 1; }
}

@keyframes checkmark-pop {
  0% { transform: scale(0); opacity: 0; }
  50% { transform: scale(1.2); opacity: 0.8; }
  100% { transform: scale(1); opacity: 1; }
}
</style>

<script>
// Code scenarios
const scenarios = {
  firebase: {
    title: 'auth_service.dart',
    successTitle: 'Authentication Service Ready!',
    successDescription: 'Firebase integration completed successfully',
    steps: [
      {
        lines: {
          5: '<span class="indent">  </span><span class="keyword">final</span> <span class="class">FirebaseAuth</span> <span class="variable">_auth</span> = <span class="class">FirebaseAuth</span>.<span class="variable">instance</span>;',
          6: '<span class="indent">  </span><span class="keyword">final</span> <span class="class">FirebaseFirestore</span> <span class="variable">_firestore</span> = <span class="class">FirebaseFirestore</span>.<span class="variable">instance</span>;'
        },
        console: '🔧 Initializing Firebase services...',
        type: 'info'
      },
      {
        lines: {
          7: '<span class="indent">  </span>',
          8: '<span class="indent">  </span><span class="comment">// User authentication method</span>',
          9: '<span class="indent">  </span><span class="keyword">Future</span>&lt;<span class="class">User</span>?&gt; <span class="function">signInWithEmail</span>(<span class="class">String</span> <span class="variable">email</span>, <span class="class">String</span> <span class="variable">password</span>) <span class="keyword">async</span> {',
          10: '<span class="indent">    </span><span class="keyword">try</span> {',
          11: '<span class="indent">      </span><span class="keyword">final</span> <span class="variable">credential</span> = <span class="keyword">await</span> <span class="variable">_auth</span>.<span class="function">signInWithEmailAndPassword</span>(',
          12: '<span class="indent">        </span><span class="variable">email</span>: <span class="variable">email</span>, <span class="variable">password</span>: <span class="error">passwd</span>',
          13: '<span class="indent">      </span>);'
        },
        console: '❌ Error: undefined name \'passwd\' (line 12)',
        type: 'error'
      },
      {
        lines: {
          12: '<span class="indent">        </span><span class="variable">email</span>: <span class="variable">email</span>, <span class="variable">password</span>: <span class="variable">password</span>'
        },
        console: '✅ Error fixed. Continuing compilation...',
        type: 'success'
      },
      {
        lines: {
          14: '<span class="indent">      </span><span class="keyword">return</span> <span class="variable">credential</span>.<span class="variable">user</span>;',
          15: '<span class="indent">    </span>} <span class="keyword">catch</span> (<span class="variable">e</span>) {',
          16: '<span class="indent">      </span><span class="function">print</span>(<span class="string">\'Authentication failed: $e\'</span>);',
          17: '<span class="indent">      </span><span class="keyword">return</span> <span class="keyword">null</span>;',
          18: '<span class="indent">    </span>}',
          19: '<span class="indent">  </span>}'
        },
        console: '🚀 Build successful! Firebase authentication ready for production.',
        type: 'success',
        isSuccess: true
      }
    ]
  },
  
  devops: {
    title: 'deploy.yml',
    successTitle: 'Deployment Pipeline Ready!',
    successDescription: 'CI/CD workflow configured successfully',
    steps: [
      {
        lines: {
          5: '<span class="keyword">name</span>: <span class="string">Deploy to Production</span>',
          6: '<span class="keyword">on</span>:',
          7: '<span class="indent">  </span><span class="keyword">push</span>:',
          8: '<span class="indent">    </span><span class="keyword">branches</span>: [<span class="string">main</span>]'
        },
        console: '🔄 Setting up CI/CD pipeline...',
        type: 'info'
      },
      {
        lines: {
          9: '<span class="keyword">jobs</span>:',
          10: '<span class="indent">  </span><span class="keyword">deploy</span>:',
          11: '<span class="indent">    </span><span class="keyword">runs-on</span>: <span class="string">ubuntu-latest</span>',
          12: '<span class="indent">    </span><span class="keyword">steps</span>:',
          13: '<span class="indent">      </span>- <span class="keyword">name</span>: <span class="string">Checkout code</span>',
          14: '<span class="indent">        </span><span class="keyword">uses</span>: <span class="string">actions/checkout@v3</span>'
        },
        console: '📦 Configuring deployment steps...',
        type: 'info'
      },
      {
        lines: {
          15: '<span class="indent">      </span>- <span class="keyword">name</span>: <span class="string">Build and Deploy</span>',
          16: '<span class="indent">        </span><span class="keyword">run</span>: |',
          17: '<span class="indent">          </span><span class="function">flutter</span> <span class="variable">build</span> <span class="variable">apk</span> <span class="variable">--release</span>',
          18: '<span class="indent">          </span><span class="function">firebase</span> <span class="variable">deploy</span> <span class="variable">--only</span> <span class="variable">hosting</span>',
          19: '<span class="indent">          </span><span class="function">echo</span> <span class="string">"Deployment completed!"</span>'
        },
        console: '🚀 Pipeline configured! Ready for automated deployment.',
        type: 'success',
        isSuccess: true
      }
    ]
  },
  
  splash: {
    title: 'splash_viewmodel.dart',
    successTitle: 'Splash Screen Logic Ready!',
    successDescription: 'User session management implemented',
    steps: [
      {
        lines: {
          5: '<span class="keyword">class</span> <span class="class">SplashViewModel</span> <span class="keyword">extends</span> <span class="class">ChangeNotifier</span> {',
          6: '<span class="indent">  </span><span class="keyword">final</span> <span class="class">AuthService</span> <span class="variable">_authService</span>;',
          7: '<span class="indent">  </span><span class="keyword">bool</span> <span class="variable">_isLoading</span> = <span class="keyword">true</span>;'
        },
        console: '🎯 Initializing splash screen viewmodel...',
        type: 'info'
      },
      {
        lines: {
          8: '<span class="indent">  </span>',
          9: '<span class="indent">  </span><span class="keyword">Future</span>&lt;<span class="keyword">void</span>&gt; <span class="function">checkUserSession</span>() <span class="keyword">async</span> {',
          10: '<span class="indent">    </span><span class="keyword">await</span> <span class="class">Future</span>.<span class="function">delayed</span>(<span class="class">Duration</span>(<span class="variable">seconds</span>: <span class="number">2</span>));',
          11: '<span class="indent">    </span>',
          12: '<span class="indent">    </span><span class="keyword">final</span> <span class="variable">user</span> = <span class="variable">_authService</span>.<span class="function">getCurrentUser</span>();'
        },
        console: '⏳ Checking user session status...',
        type: 'info'
      },
      {
        lines: {
          13: '<span class="indent">    </span><span class="keyword">if</span> (<span class="variable">user</span> != <span class="keyword">null</span>) {',
          14: '<span class="indent">      </span><span class="comment">// User is logged in, navigate to main app</span>',
          15: '<span class="indent">      </span><span class="function">navigateToHome</span>();',
          16: '<span class="indent">    </span>} <span class="keyword">else</span> {',
          17: '<span class="indent">      </span><span class="comment">// User not logged in, show login screen</span>',
          18: '<span class="indent">      </span><span class="function">navigateToLogin</span>();',
          19: '<span class="indent">    </span>}'
        },
        console: '✅ Session check completed! Navigation logic implemented.',
        type: 'success',
        isSuccess: true
      }
    ]
  }
};

let currentScenario = 'firebase';
let isAnimating = false;
let animationTimeout = null;

function updateStatus(status, text) {
  const dot = document.getElementById('status-dot');
  const statusText = document.getElementById('status-text');
  
  if (dot && statusText) {
    dot.className = `status-dot ${status}`;
    statusText.textContent = text;
  }
}

async function deployAnimation() {
  // Stop current animation
  isAnimating = true;
  if (animationTimeout) {
    clearTimeout(animationTimeout);
  }
  
  const consoleOutput = document.getElementById('console-output');
  const successOverlay = document.getElementById('success-overlay');
  
  if (!consoleOutput) return;
  
  // Hide success overlay first
  if (successOverlay) {
    successOverlay.classList.remove('show');
  }
  
  const deploySteps = [
    '🚀 Starting deployment process...',
    '📦 Building application bundle...',
    '⬆️ Uploading to Firebase hosting...',
    '🔧 Configuring deployment settings...',
    '✅ Deployment completed successfully!',
    '🌐 App is live at: https://your-app.web.app'
  ];
  
  updateStatus('coding', 'Deploying');
  
  // Clear console and animate each step
  consoleOutput.innerHTML = '';
  
  for (let i = 0; i < deploySteps.length; i++) {
    if (!isAnimating) break;
    
    const step = deploySteps[i];
    await typeText(consoleOutput, `<span class="success-message">${step}</span>`, 40);
    
    if (i < deploySteps.length - 1) {
      await new Promise(resolve => setTimeout(resolve, 1200));
    }
  }
  
  updateStatus('success', 'Deployed');
  
  setTimeout(() => {
    updateStatus('', 'Ready');
    isAnimating = false;
    // Restart the current scenario after deploy
    setTimeout(() => {
      if (!isAnimating) {
        animateScenario(currentScenario);
      }
    }, 1000);
  }, 2000);
}

function typeText(element, text, speed = 30) {
  return new Promise(resolve => {
    if (!element) {
      resolve();
      return;
    }
    
    element.innerHTML = '';
    let i = 0;
    
    const timer = setInterval(() => {
      if (!isAnimating && element.id.startsWith('line-')) {
        clearInterval(timer);
        resolve();
        return;
      }
      
      if (i <= text.length) {
        const currentText = text.slice(0, i);
        element.innerHTML = currentText;
        i++;
      } else {
        element.innerHTML = text;
        clearInterval(timer);
        resolve();
      }
    }, speed);
  });
}

async function updateConsole(message, type = 'info') {
  const console = document.getElementById('console-output');
  if (!console) return;
  
  const messageClass = type === 'error' ? 'error-message' : 
                      type === 'success' ? 'success-message' : 'info-message';
  
  await typeText(console, `<span class="${messageClass}">${message}</span>`, 40);
}

async function updateCodeLine(lineId, content) {
  const line = document.getElementById(lineId);
  if (line) {
    await typeText(line, content, 25);
  }
}

async function animateStep(stepData) {
  // Update code lines
  for (const [lineId, content] of Object.entries(stepData.lines)) {
    await updateCodeLine(`line-${lineId}`, content);
    await new Promise(resolve => setTimeout(resolve, 100));
  }
  
  // Update console
  await new Promise(resolve => setTimeout(resolve, 300));
  await updateConsole(stepData.console, stepData.type);
  
  // Show success overlay if completed
  if (stepData.isSuccess) {
    setTimeout(() => {
      document.getElementById('success-overlay')?.classList.add('show');
    }, 1000);
  }
}

async function animateScenario(scenarioName) {
  if (isAnimating) return;
  isAnimating = true;
  
  // Clear any existing timeout
  if (animationTimeout) {
    clearTimeout(animationTimeout);
  }
  
  const scenario = scenarios[scenarioName];
  currentScenario = scenarioName;
  
  // Update UI
  const editorTitle = document.getElementById('editor-title');
  const successTitle = document.getElementById('success-title');
  const successDescription = document.getElementById('success-description');
  
  if (editorTitle) editorTitle.textContent = scenario.title;
  if (successTitle) successTitle.textContent = scenario.successTitle;
  if (successDescription) successDescription.textContent = scenario.successDescription;
  
  // Update active button
  document.querySelectorAll('.action-btn').forEach(btn => btn.classList.remove('active'));
  const activeBtn = document.querySelector(`[data-scenario="${scenarioName}"]`);
  if (activeBtn) activeBtn.classList.add('active');
  
  // Reset editor
  const successOverlay = document.getElementById('success-overlay');
  if (successOverlay) successOverlay.classList.remove('show');
  
  const consoleEl = document.getElementById('console-output');
  if (consoleEl) consoleEl.innerHTML = '';
  
  for (let i = 5; i <= 19; i++) {
    const line = document.getElementById(`line-${i}`);
    if (line) line.innerHTML = '<span class="indent">  </span>';
  }
  
  updateStatus('coding', 'Coding');
  
  // Wait for initial load
  await new Promise(resolve => setTimeout(resolve, 500));
  
  // Animate scenario steps
  for (let i = 0; i < scenario.steps.length && isAnimating; i++) {
    await animateStep(scenario.steps[i]);
    if (isAnimating) {
      await new Promise(resolve => setTimeout(resolve, 1500));
    }
  }
  
  if (isAnimating) {
    updateStatus('success', 'Complete');
    isAnimating = false;
    
    // Auto-restart after completion
    animationTimeout = setTimeout(() => {
      if (!isAnimating) {
        animateScenario(currentScenario);
      }
    }, 8000);
  }
}

// Initialize
document.addEventListener('DOMContentLoaded', () => {
  // Set firebase as default active
  const firebaseBtn = document.querySelector('[data-scenario="firebase"]');
  if (firebaseBtn) firebaseBtn.classList.add('active');
  
  // Start animation
  setTimeout(() => {
    animateScenario('firebase');
  }, 100);
  
  // Action buttons
  document.querySelectorAll('.action-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const scenario = btn.dataset.scenario;
      if (scenario && !isAnimating) {
        // Clear any existing timeout
        if (animationTimeout) {
          clearTimeout(animationTimeout);
        }
        animateScenario(scenario);
      }
    });
  });
  
  // Refresh button
  const refreshBtn = document.getElementById('refresh-btn');
  if (refreshBtn) {
    refreshBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (!isAnimating) {
        // Clear any existing timeout
        if (animationTimeout) {
          clearTimeout(animationTimeout);
        }
        animateScenario(currentScenario);
      }
    });
  }
  
  // Deploy button
  const deployBtn = document.getElementById('deploy-btn');
  if (deployBtn) {
    deployBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (!isAnimating) {
        deployAnimation();
      }
    });
  }
});
</script>
