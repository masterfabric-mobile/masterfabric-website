---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  targetBlank?: boolean;
  style?: "outline" | "primary" | "inverted" | "active";
  class?: string;
  [x: string]: any;
}

const {
  href,
  size = "md",
  block,
  targetBlank,
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  md: "px-5 py-2.5",
  lg: "px-6 py-3",
};

const styles = {
  outline: "border-2 border-black hover:bg-black text-black hover:text-white",
  primary: "bg-black text-white hover:bg-slate-900 border-2 border-transparent",
  inverted: "bg-white text-black hover:bg-gray-100 border-2 border-transparent",
  active: "border border-blue-200 bg-blue-50 text-blue-600 font-medium border-2"
};
---

<a
  href={href}
  {...rest}
  target={targetBlank ? "_blank" : "_parent"}
  class:list={[
    "rounded-lg text-center transition focus-visible:ring-2 ring-offset-2 ring-gray-200",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
