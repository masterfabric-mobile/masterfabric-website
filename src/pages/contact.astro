---
import Contactform from "@components/forms/contactform.astro";
import Container from "@components/layout/container.astro";
import Layout from "@layouts/layout.astro";
import { Icon } from "astro-icon/components";
import Button from "@components/ui/button.astro";
import fs from "fs";
import path from "path";

// Load contact data from JSON file
const contactDataPath = path.join(process.cwd(), "src/data/contact.json");
const contactDataContent = fs.readFileSync(contactDataPath, "utf-8");
const contactData = JSON.parse(contactDataContent);
---

<Layout title="Contact">
  <Container>
    <section class="py-16 lg:py-24 bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="grid lg:grid-cols-2 gap-16 items-start">
          
          <!-- LEFT COLUMN - CONTENT AREA -->
          <div class="space-y-8">
            <div class="space-y-6">
              <!-- Main Heading -->
              <h1 class="text-4xl lg:text-5xl xl:text-6xl font-bold text-gray-900 leading-tight">
                <span class="block">Are You Ready to</span>
                <span class="block">Build Something</span>
                <span class="block text-blue-600">Great Together?</span>
              </h1>
              
              <!-- Description Paragraph -->
              <p class="text-lg lg:text-xl text-gray-600 leading-relaxed max-w-2xl">
                Contact us today and let's discuss your project. Whether you have a full plan or just an idea, we are ready to help you every step of the way.
              </p>
            </div>

            <!-- Contact Information -->
            <div class="space-y-6 pt-8">
              <div class="flex items-start space-x-4 group">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-full flex items-center justify-center text-white transition-transform duration-300 group-hover:scale-110">
                    <Icon class="w-6 h-6" name="uil:map-marker" />
                  </div>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 group-hover:text-gray-700 transition-colors duration-300">Office Location</h3>
                  <p class="text-gray-600 text-sm group-hover:text-gray-500 transition-colors duration-300">
                    Şehit Muhtar Mahallesi Mis Sokak. No. 24/28<br>
                    Beyoğlu / İstanbul, Turkey
                  </p>
                </div>
              </div>

              <div class="flex items-start space-x-4 group">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-green-600 rounded-full flex items-center justify-center text-white transition-transform duration-300 group-hover:scale-110">
                    <Icon class="w-6 h-6" name="uil:envelope" />
                  </div>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 group-hover:text-gray-700 transition-colors duration-300">Email Address</h3>
                  <a href="mailto:info@masterfabric.co" class="text-gray-600 text-sm group-hover:text-blue-600 transition-colors duration-300">
                    info@masterfabric.co
                  </a>
                </div>
              </div>

              <div class="flex items-start space-x-4 group">
                <div class="flex-shrink-0">
                  <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-purple-600 rounded-full flex items-center justify-center text-white transition-transform duration-300 group-hover:scale-110">
                    <Icon class="w-6 h-6" name="uil:clock" />
                  </div>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 group-hover:text-gray-700 transition-colors duration-300">Business Hours</h3>
                  <p class="text-gray-600 text-sm group-hover:text-gray-500 transition-colors duration-300">
                    Monday - Friday: 9:00 AM - 6:00 PM<br>
                    Saturday: 10:00 AM - 4:00 PM
                  </p>
                </div>
              </div>
            </div>

            <!-- Interactive Map -->
            <div class="pt-8">
              <h3 class="text-xl font-semibold text-gray-900 mb-4">Find Us on the Map</h3>
              <div class="relative rounded-2xl overflow-hidden shadow-xl border border-gray-200 h-64 lg:h-80">
                <div id="map" class="w-full h-full"></div>
                <div class="absolute top-4 right-4 bg-white rounded-lg shadow-lg p-2 opacity-90">
                  <button id="reset-map" class="text-gray-600 hover:text-gray-800 transition-colors duration-200" title="Reset Map View">
                    <Icon class="w-5 h-5" name="uil:focus-target" />
                  </button>
                </div>
              </div>
              
              <!-- Mobile Navigation Button -->
              <div id="mobile-navigation" class="mt-4 hidden">
                <button 
                  id="navigate-button"
                  class="w-full bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-medium py-3 px-4 rounded-xl transition-all duration-300 transform hover:scale-[1.02] active:scale-[0.98] shadow-lg hover:shadow-xl flex items-center justify-center space-x-2">
                  <Icon class="w-5 h-5" name="uil:location-arrow" />
                  <span id="navigate-text">Navigate to Office</span>
                </button>
              </div>
            </div>
          </div>

          <!-- RIGHT COLUMN - CONTACT FORM -->
          <div class="lg:pl-8">
            <div class="bg-white border border-gray-200 rounded-2xl shadow-xl p-8 lg:p-10">
              
              <!-- Initial Stage - Call to Action -->
              <div id="initial-stage" class="stage-container text-center">
                <div class="mb-8">
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">Get in Touch</h3>
                  <p class="text-gray-600">Ready to start your project? Fill out the form below and we'll get back to you within 24 hours.</p>
                </div>
                <Button 
                  id="show-form-btn" 
                  size="lg" 
                  class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-lg transition-colors duration-200 w-full">
                  Start Your Project
                </Button>
              </div>

              <!-- Return Visitor Notifications -->
              <div id="return-visitor-notification" class="stage-container hidden">
                <div id="notification-content" class="text-center space-y-4">
                  <!-- Dynamic notification content will be inserted here -->
                </div>
              </div>

              <!-- Form Stage -->
              <div id="form-stage" class="stage-container hidden">
                <div class="mb-8">
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">Project Details</h3>
                  <p class="text-gray-600">Tell us about your project and we'll get back to you soon.</p>
                </div>
                
                <!-- Contact Form -->
                <form
                  action="https://api.web3forms.com/submit"
                  method="POST"
                  id="contact-form"
                  class="needs-validation space-y-6"
                  novalidate>
                  
                  <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
                  <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
                  
                  <!-- Name Field -->
                  <div>
                    <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                    <input
                      type="text"
                      id="name"
                      name="name"
                      required
                      placeholder="Enter your full name"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400"
                    />
                    <div class="empty-feedback invalid-feedback text-red-500 text-sm mt-1">
                      Please enter your full name.
                    </div>
                  </div>

                  <!-- Email Field -->
                  <div>
                    <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                    <input
                      type="email"
                      id="email"
                      name="email"
                      required
                      placeholder="Enter your email address"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400"
                    />
                    <div class="empty-feedback text-red-500 text-sm mt-1">
                      Please enter your email address.
                    </div>
                    <div class="invalid-feedback text-red-500 text-sm mt-1">
                      Please enter a valid email address.
                    </div>
                  </div>

                  <!-- Phone Field -->
                  <div>
                    <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                    <input
                      type="tel"
                      id="phone"
                      name="phone"
                      placeholder="Enter your phone number"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400"
                    />
                  </div>

                  <!-- Project Type Field -->
                  <div>
                    <label for="project-type" class="block text-sm font-medium text-gray-700 mb-2">Project Type</label>
                    <select
                      id="project-type"
                      name="project-type"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200">
                      <option value="">Select project type</option>
                      <option value="web-development">Web Development</option>
                      <option value="mobile-app">Mobile App</option>
                      <option value="ecommerce">E-commerce</option>
                      <option value="consulting">Consulting</option>
                      <option value="other">Other</option>
                    </select>
                  </div>

                  <!-- Message Field -->
                  <div>
                    <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Project Description</label>
                    <textarea
                      id="message"
                      name="message"
                      required
                      rows="4"
                      placeholder="Tell us about your project..."
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200 placeholder:text-gray-400 resize-vertical"></textarea>
                    <div class="empty-feedback invalid-feedback text-red-500 text-sm mt-1">
                      Please tell us about your project.
                    </div>
                  </div>

                  <!-- Budget Range -->
                  <div>
                    <label for="budget" class="block text-sm font-medium text-gray-700 mb-2">Budget Range</label>
                    <select
                      id="budget"
                      name="budget"
                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-colors duration-200">
                      <option value="">Select budget range</option>
                      <option value="under-5k">Under $5,000</option>
                      <option value="5k-10k">$5,000 - $10,000</option>
                      <option value="10k-25k">$10,000 - $25,000</option>
                      <option value="25k-50k">$25,000 - $50,000</option>
                      <option value="over-50k">Over $50,000</option>
                    </select>
                  </div>

                  <!-- Form Actions -->
                  <div class="flex flex-col gap-3">
                    <Button 
                      type="submit" 
                      size="lg" 
                      class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-200 w-full submit-button">
                      Send Message
                    </Button>
                    <div class="text-center">
                      <button 
                        type="button" 
                        id="back-to-initial-btn"
                        class="text-gray-600 hover:text-gray-800 text-sm font-medium transition-colors duration-200">
                        ← Back
                      </button>
                    </div>
                  </div>

                  <!-- Result Message -->
                  <div id="form-result" class="text-center"></div>
                </form>
              </div>

              <!-- Success Stage -->
              <div id="success-stage" class="stage-container hidden text-center">
                <div class="mb-8">
                  <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                  </div>
                  <h3 class="text-2xl font-bold text-gray-900 mb-2">Message Sent!</h3>
                  <p class="text-gray-600">Thank you for contacting us. We'll get back to you within 24 hours.</p>
                </div>
                <Button 
                  id="back-to-home-btn"
                  class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-6 rounded-lg transition-colors duration-200 w-full">
                  Continue Browsing
                </Button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </Container>
</Layout>

<style>
  /* Map container styling */
  #map {
    background: #f8fafc;
    position: relative;
  }

  /* Leaflet control styling */
  :global(.leaflet-control-container .leaflet-control) {
    background: rgba(255, 255, 255, 0.95);
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  :global(.leaflet-control-zoom a) {
    color: #374151;
    border-radius: 6px;
    transition: all 0.2s ease;
  }

  :global(.leaflet-control-zoom a:hover) {
    background: #f3f4f6;
    color: #1f2937;
  }

  :global(.leaflet-popup-content-wrapper) {
    border-radius: 12px;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  :global(.leaflet-popup-content) {
    margin: 16px;
    font-family: system-ui, -apple-system, sans-serif;
  }

  /* Map loading animation */
  .map-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    background: linear-gradient(45deg, #f8fafc, #e2e8f0);
  }

  .loading-spinner {
    width: 32px;
    height: 32px;
    border: 3px solid #e2e8f0;
    border-top: 3px solid #3b82f6;
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #ef4444;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.1);
  }

  /* Stage Transition Animations */
  .stage-container {
    transition: opacity 0.2s ease;
    opacity: 1;
  }

  .stage-container.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .stage-container:not(.hidden) {
    opacity: 1;
    pointer-events: auto;
  }

  /* Form submission loading animation */
  .form-submitting {
    pointer-events: none;
    opacity: 0.7;
  }

  .form-submitting .submit-button {
    position: relative;
    overflow: hidden;
  }

  .form-submitting .submit-button::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    animation: submitShimmer 1.5s infinite;
  }

  @keyframes submitShimmer {
    0% { left: -100%; }
    100% { left: 100%; }
  }

  /* Mobile Navigation Button Animation */
  #navigate-button {
    position: relative;
    overflow: hidden;
  }

  #navigate-button::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s;
  }

  #navigate-button:hover::before {
    left: 100%;
  }

  /* iOS Modal Styling */
  .ios-modal {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
  }

  .ios-modal.show {
    opacity: 1;
    visibility: visible;
  }

  .ios-modal-content {
    background: white;
    border-radius: 14px;
    margin: 20px;
    max-width: 320px;
    width: 100%;
    overflow: hidden;
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .ios-modal.show .ios-modal-content {
    transform: scale(1);
  }

  .ios-modal-header {
    padding: 20px 20px 16px;
    text-align: center;
    border-bottom: 1px solid #e5e5e7;
  }

  .ios-modal-title {
    font-size: 17px;
    font-weight: 600;
    color: #000;
    margin: 0 0 4px;
  }

  .ios-modal-message {
    font-size: 13px;
    color: #8e8e93;
    margin: 0;
  }

  .ios-modal-actions {
    display: flex;
    flex-direction: column;
  }

  .ios-modal-button {
    padding: 16px 20px;
    border: none;
    background: none;
    font-size: 17px;
    cursor: pointer;
    transition: background-color 0.2s ease;
    border-bottom: 1px solid #e5e5e7;
  }

  .ios-modal-button:last-child {
    border-bottom: none;
  }

  .ios-modal-button.primary {
    color: #007aff;
    font-weight: 600;
  }

  .ios-modal-button.secondary {
    color: #007aff;
  }

  .ios-modal-button.cancel {
    color: #ff3b30;
  }

  .ios-modal-button:hover {
    background-color: #f2f2f7;
  }

  .ios-modal-button:active {
    background-color: #e5e5ea;
  }
</style>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

<!-- Leaflet JS -->
<script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

<script is:inline>
  // Mobile Device Detection Utility
  class MobileDetector {
    static isIOS() {
      return /iPad|iPhone|iPod/.test(navigator.userAgent) && !window.MSStream;
    }

    static isAndroid() {
      return /Android/.test(navigator.userAgent);
    }

    static isMobile() {
      return this.isIOS() || this.isAndroid() || 
             /Mobi|Android/i.test(navigator.userAgent) ||
             (window.innerWidth <= 768);
    }

    static getOS() {
      if (this.isIOS()) return 'ios';
      if (this.isAndroid()) return 'android';
      return 'other';
    }

    static hasNativeMapApp() {
      return this.isIOS() || this.isAndroid();
    }
  }

  // Map Navigation Manager
  class MapNavigationManager {
    constructor(coordinates) {
      this.coordinates = coordinates;
      this.destinationAddress = "Şehit Muhtar Mahallesi Mis Sokak. No. 24/28, Beyoğlu, İstanbul, Turkey";
      this.init();
    }

    init() {
      if (MobileDetector.isMobile()) {
        this.showNavigationButton();
        this.bindNavigationEvents();
      }
    }

    showNavigationButton() {
      const mobileNavContainer = document.getElementById('mobile-navigation');
      const navigateButton = document.getElementById('navigate-button');
      const navigateText = document.getElementById('navigate-text');
      
      if (mobileNavContainer && navigateButton && navigateText) {
        mobileNavContainer.classList.remove('hidden');
        
        // Update button text based on device
        const os = MobileDetector.getOS();
        switch(os) {
          case 'ios':
            navigateText.textContent = 'Navigate with Maps';
            break;
          case 'android':
            navigateText.textContent = 'Navigate with Google Maps';
            break;
          default:
            navigateText.textContent = 'Navigate to Office';
        }
      }
    }

    bindNavigationEvents() {
      const navigateButton = document.getElementById('navigate-button');
      if (navigateButton) {
        navigateButton.addEventListener('click', () => this.handleNavigation());
      }
    }

    handleNavigation() {
      const os = MobileDetector.getOS();
      
      switch(os) {
        case 'ios':
          this.handleIOSNavigation();
          break;
        case 'android':
          this.openGoogleMaps();
          break;
        default:
          this.openGoogleMaps();
      }
    }

    handleIOSNavigation() {
      // Show iOS-style modal for app selection
      this.showIOSModal();
    }

    showIOSModal() {
      const modalHtml = `
        <div id="ios-map-modal" class="ios-modal">
          <div class="ios-modal-content">
            <div class="ios-modal-header">
              <h3 class="ios-modal-title">Choose Map App</h3>
              <p class="ios-modal-message">Select how you'd like to navigate to our office</p>
            </div>
            <div class="ios-modal-actions">
              <button class="ios-modal-button primary" onclick="mapNavigationManager.openAppleMaps()">
                Open in Apple Maps
              </button>
              <button class="ios-modal-button secondary" onclick="mapNavigationManager.openGoogleMaps()">
                Open in Google Maps
              </button>
              <button class="ios-modal-button cancel" onclick="mapNavigationManager.closeIOSModal()">
                Cancel
              </button>
            </div>
          </div>
        </div>
      `;

      // Remove existing modal if present
      const existingModal = document.getElementById('ios-map-modal');
      if (existingModal) {
        existingModal.remove();
      }

      // Add modal to body
      document.body.insertAdjacentHTML('beforeend', modalHtml);
      
      // Show modal with animation
      setTimeout(() => {
        const modal = document.getElementById('ios-map-modal');
        if (modal) {
          modal.classList.add('show');
        }
      }, 10);

      // Close modal when clicking backdrop
      const modal = document.getElementById('ios-map-modal');
      if (modal) {
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            this.closeIOSModal();
          }
        });
      }
    }

    closeIOSModal() {
      const modal = document.getElementById('ios-map-modal');
      if (modal) {
        modal.classList.remove('show');
        setTimeout(() => {
          modal.remove();
        }, 300);
      }
    }

    openAppleMaps() {
      const [lat, lng] = this.coordinates;
      const appleMapsUrl = `maps://maps.apple.com/?daddr=${lat},${lng}&dirflg=d`;
      
      // Try to open Apple Maps
      window.location.href = appleMapsUrl;
      
      // Fallback to Google Maps if Apple Maps fails
      setTimeout(() => {
        this.openGoogleMaps();
      }, 1000);
      
      this.closeIOSModal();
    }

    openGoogleMaps() {
      const [lat, lng] = this.coordinates;
      const encodedAddress = encodeURIComponent(this.destinationAddress);
      
      // Try native Google Maps app first with the exact address
      const googleMapsApp = `comgooglemaps://?daddr=${encodedAddress}&directionsmode=driving`;
      
      // For mobile devices, try to open the app
      if (MobileDetector.isMobile()) {
        // Create a temporary link to test if the app opens
        const tempLink = document.createElement('a');
        tempLink.href = googleMapsApp;
        tempLink.click();
        
        // Fallback to web version with exact address after a short delay
        setTimeout(() => {
          const googleMapsWeb = `https://www.google.com/maps/dir/?api=1&destination=${encodedAddress}&travelmode=driving`;
          window.open(googleMapsWeb, '_blank');
        }, 500);
      } else {
        // For desktop, open web version directly with exact address
        const googleMapsWeb = `https://www.google.com/maps/dir/?api=1&destination=${encodedAddress}&travelmode=driving`;
        window.open(googleMapsWeb, '_blank');
      }
      
      this.closeIOSModal();
    }
  }

  // Modern Map Implementation
  class ModernMapManager {
    constructor() {
      this.map = null;
      this.marker = null;
      // Updated coordinates for exact address: Şehit Muhtar Mahallesi Mis Sokak. No. 24/28, Beyoğlu
      this.coordinates = [41.0345, 28.9845]; // More precise coordinates for the exact street
      this.init();
    }

    init() {
      // Wait for both DOM and Leaflet to be ready
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => this.initializeMap());
      } else {
        this.initializeMap();
      }
    }

    initializeMap() {
      // Check if Leaflet is available
      if (typeof L === 'undefined') {
        console.warn('Leaflet not loaded, retrying...');
        setTimeout(() => this.initializeMap(), 100);
        return;
      }

      const mapContainer = document.getElementById('map');
      if (!mapContainer) {
        console.warn('Map container not found');
        return;
      }

      // Initialize navigation manager
      window.mapNavigationManager = new MapNavigationManager(this.coordinates);

      // Show loading state
      mapContainer.innerHTML = `
        <div class="map-loading">
          <div class="loading-spinner"></div>
        </div>
      `;

      try {
        // Initialize map with modern styling
        this.map = L.map('map', {
          center: this.coordinates,
          zoom: 16,
          zoomControl: false,
          scrollWheelZoom: true,
          touchZoom: true,
          doubleClickZoom: true,
          attributionControl: true
        });

        // Add custom zoom control in top-left
        L.control.zoom({
          position: 'topleft'
        }).addTo(this.map);

        // Use OpenStreetMap with modern styling
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
          maxZoom: 19,
          className: 'map-tiles'
        }).addTo(this.map);

        // Custom marker icon
        const customIcon = L.divIcon({
          html: `
            <div style="
              width: 40px;
              height: 40px;
              background: linear-gradient(135deg, #3b82f6, #1d4ed8);
              border-radius: 50% 50% 50% 0;
              transform: rotate(-45deg);
              border: 3px solid white;
              box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
              display: flex;
              align-items: center;
              justify-content: center;
            ">
              <div style="
                width: 12px;
                height: 12px;
                background: white;
                border-radius: 50%;
                transform: rotate(45deg);
              "></div>
            </div>
          `,
          className: 'custom-marker',
          iconSize: [40, 40],
          iconAnchor: [20, 35],
          popupAnchor: [0, -35]
        });

        // Add marker with popup
        this.marker = L.marker(this.coordinates, { 
          icon: customIcon,
          riseOnHover: true 
        }).addTo(this.map);

        // Custom popup content with exact address
        const popupContent = `
          <div style="text-align: center; min-width: 200px;">
            <h3 style="margin: 0 0 8px 0; color: #1f2937; font-size: 16px; font-weight: 600;">
              MasterFabric Office
            </h3>
            <p style="margin: 0 0 12px 0; color: #6b7280; font-size: 14px; line-height: 1.4;">
              Şehit Muhtar Mahallesi<br>
              Mis Sokak. No. 24/28<br>
              Beyoğlu, İstanbul, Turkey
            </p>
            <a 
              href="https://www.google.com/maps/search/?api=1&query=Şehit+Muhtar+Mahallesi+Mis+Sokak+No+24%2F28+Beyoğlu+İstanbul+Turkey" 
              target="_blank"
              style="
                display: inline-block;
                background: linear-gradient(135deg, #3b82f6, #1d4ed8);
                color: white;
                padding: 6px 12px;
                border-radius: 6px;
                text-decoration: none;
                font-size: 12px;
                font-weight: 500;
                transition: all 0.2s ease;
              "
              onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 4px 12px rgba(59, 130, 246, 0.4)'"
              onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='none'"
            >
              Navigate to Office
            </a>
          </div>
        `;

        this.marker.bindPopup(popupContent, {
          maxWidth: 250,
          closeButton: true,
          className: 'modern-popup'
        });

        // Add reset map button functionality
        const resetButton = document.getElementById('reset-map');
        if (resetButton) {
          resetButton.addEventListener('click', () => {
            this.map.setView(this.coordinates, 16, { animate: true, duration: 0.5 });
          });
        }

        // Add subtle animation when map loads
        setTimeout(() => {
          this.map.invalidateSize();
        }, 100);

        console.log('Map initialized successfully');
        
      } catch (error) {
        console.error('Error initializing map:', error);
        mapContainer.innerHTML = `
          <div class="map-loading">
            <div style="text-align: center; color: #6b7280;">
              <p>Map temporarily unavailable</p>
              <a href="https://www.google.com/maps/search/?api=1&query=Şehit+Muhtar+Mahallesi+Mis+Sokak+No+24%2F28+Beyoğlu+İstanbul+Turkey" 
                 target="_blank" 
                 style="color: #3b82f6; text-decoration: underline; font-size: 14px;">
                Navigate to Office
              </a>
            </div>
          </div>
        `;
      }
    }
  }

  // Initialize map manager
  window.modernMapManager = new ModernMapManager();

  // Contact Form State Management
  class ContactFormManager {
    constructor() {
      this.stages = {
        INITIAL: 'initial',
        FORM: 'form',
        SUCCESS: 'success',
        NOTIFICATION: 'notification'
      };
      
      this.currentStage = this.stages.INITIAL;
      this.isTransitioning = false;
      
      this.init();
    }

    init() {
      this.checkReturnVisitor();
      this.bindEvents();
    }

    checkReturnVisitor() {
      const contactHistory = this.getContactHistory();
      if (contactHistory.length > 0) {
        const lastContact = contactHistory[contactHistory.length - 1];
        const daysSinceContact = Math.floor((Date.now() - lastContact.timestamp) / (1000 * 60 * 60 * 24));
        
        let notificationType;
        if (daysSinceContact < 1) {
          notificationType = 'recent-contact';
        } else if (daysSinceContact < 3) {
          notificationType = 'pending-response';
        } else {
          notificationType = 'no-response';
        }
        
        this.showReturnVisitorNotification(notificationType);
      }
    }

    showReturnVisitorNotification(type) {
      const notifications = {
        'recent-contact': {
          icon: '⏱️',
          title: 'We received your message!',
          message: 'Thank you for contacting us recently. We\'ll respond within 24 hours.',
          actions: [
            { action: 'check-email', text: 'Check Email' },
            { action: 'new-message', text: 'Send New Message' }
          ]
        },
        'pending-response': {
          icon: '📬',
          title: 'Your message is being reviewed',
          message: 'Our team is working on your request. You should hear from us soon.',
          actions: [
            { action: 'check-email', text: 'Check Email' },
            { action: 'resend', text: 'Follow Up' }
          ]
        },
        'no-response': {
          icon: '🔄',
          title: 'Welcome back!',
          message: 'We haven\'t been able to reach you. Would you like to try again?',
          actions: [
            { action: 'new-message', text: 'Send New Message' }
          ]
        }
      };

      const notification = notifications[type];
      if (!notification) return;

      const notificationHtml = `
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 mb-6">
          <div class="flex items-center justify-center mb-4">
            <div class="text-3xl">${notification.icon}</div>
          </div>
          <h4 class="text-lg font-semibold text-gray-900 mb-2">${notification.title}</h4>
          <p class="text-gray-600 mb-4">${notification.message}</p>
          <div class="flex gap-2 justify-center flex-wrap">
            ${notification.actions.map(action => `
              <button 
                class="px-4 py-2 text-sm font-medium rounded-lg transition-colors duration-200 ${
                  action.action === 'new-message' || action.action === 'resend' 
                    ? 'bg-blue-600 text-white hover:bg-blue-700' 
                    : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                }"
                onclick="contactFormManager.handleNotificationAction('${action.action}')">
                ${action.text}
              </button>
            `).join('')}
          </div>
        </div>
        <div class="text-center">
          <button 
            id="show-form-from-notification-btn"
            onclick="contactFormManager.clearCacheAndStartFresh()"
            class="text-blue-600 hover:text-blue-700 text-sm font-medium">
            Or start fresh
          </button>
        </div>
      `;

      document.getElementById('notification-content').innerHTML = notificationHtml;
      this.showStage(this.stages.NOTIFICATION);
    }

    handleNotificationAction(action) {
      switch(action) {
        case 'check-email':
          window.location.href = 'mailto:';
          break;
        case 'new-message':
        case 'resend':
          this.showStage(this.stages.FORM);
          break;
      }
    }

    bindEvents() {
      // Show form button
      const showFormBtn = document.getElementById('show-form-btn');
      if (showFormBtn) {
        showFormBtn.addEventListener('click', () => this.showStage(this.stages.FORM));
      }

      // Back to initial button
      const backToInitialBtn = document.getElementById('back-to-initial-btn');
      if (backToInitialBtn) {
        backToInitialBtn.addEventListener('click', () => this.showStage(this.stages.INITIAL));
      }

      // Back to home button
      const backToHomeBtn = document.getElementById('back-to-home-btn');
      if (backToHomeBtn) {
        backToHomeBtn.addEventListener('click', () => this.showStage(this.stages.INITIAL));
      }

      // Form submission
      const contactForm = document.getElementById('contact-form');
      if (contactForm) {
        contactForm.addEventListener('submit', (e) => this.handleFormSubmit(e));
      }
    }

    showStage(stage) {
      if (this.isTransitioning) {
        return Promise.resolve();
      }

      const currentStageEl = this.getCurrentStageElement();
      const nextStageEl = this.getStageElement(stage);
      
      if (!nextStageEl || currentStageEl === nextStageEl) {
        return Promise.resolve();
      }

      this.isTransitioning = true;

      return new Promise((resolve) => {
        if (currentStageEl) {
          currentStageEl.classList.add('hidden');
        }

        nextStageEl.classList.remove('hidden');
        this.currentStage = stage;
        this.isTransitioning = false;
        
        resolve();
      });
    }

    getCurrentStageElement() {
      switch(this.currentStage) {
        case this.stages.INITIAL:
          return document.getElementById('initial-stage');
        case this.stages.FORM:
          return document.getElementById('form-stage');
        case this.stages.SUCCESS:
          return document.getElementById('success-stage');
        case this.stages.NOTIFICATION:
          return document.getElementById('return-visitor-notification');
        default:
          return document.getElementById('initial-stage');
      }
    }

    getStageElement(stage) {
      switch(stage) {
        case this.stages.INITIAL:
          return document.getElementById('initial-stage');
        case this.stages.FORM:
          return document.getElementById('form-stage');
        case this.stages.SUCCESS:
          return document.getElementById('success-stage');
        case this.stages.NOTIFICATION:
          return document.getElementById('return-visitor-notification');
        default:
          return null;
      }
    }

    async handleFormSubmit(e) {
      e.preventDefault();
      const form = e.target;
      form.classList.add('was-validated');
      
      if (!form.checkValidity()) {
        form.querySelectorAll(':invalid')[0].focus();
        return;
      }

      const formData = new FormData(form);
      const object = Object.fromEntries(formData);
      const json = JSON.stringify(object);

      const submitButton = form.querySelector('button[type="submit"]');
      const formResult = document.getElementById('form-result');
      
      // Set loading state
      form.classList.add('form-submitting');
      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Sending...';
      }

      formResult.innerHTML = `
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
          <p class="text-blue-800">
            <svg class="inline w-5 h-5 mr-2 animate-spin" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
            </svg>
            Sending your message...
          </p>
        </div>
      `;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: json,
        });

        const result = await response.json();
        
        if (response.status === 200) {
          // Save contact to history
          this.saveContactToHistory({
            email: object.email,
            timestamp: Date.now(),
            name: object.name
          });

          // Show success message
          formResult.innerHTML = `
            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
              <p class="text-green-800">
                <svg class="inline w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path>
                </svg>
                Message sent successfully!
              </p>
            </div>
          `;

          // Transition to success stage
          setTimeout(() => {
            this.showStage(this.stages.SUCCESS);
          }, 1200);
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        // Reset loading state and show error
        form.classList.remove('form-submitting');
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.textContent = 'Send Message';
        }

        formResult.innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <p class="text-red-800">
              <svg class="inline w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"></path>
              </svg>
              Something went wrong. Please try again.
            </p>
          </div>
        `;
      }
    }

    getContactHistory() {
      try {
        const history = localStorage.getItem('masterfabric_contact_history');
        return history ? JSON.parse(history) : [];
      } catch {
        return [];
      }
    }

    saveContactToHistory(contact) {
      try {
        const history = this.getContactHistory();
        history.push(contact);
        if (history.length > 5) {
          history.splice(0, history.length - 5);
        }
        localStorage.setItem('masterfabric_contact_history', JSON.stringify(history));
      } catch (error) {
        console.warn('Could not save contact history:', error);
      }
    }

    clearCacheAndStartFresh() {
      try {
        localStorage.removeItem('masterfabric_contact_history');
        this.showStage(this.stages.INITIAL);
      } catch (error) {
        console.warn('Could not clear contact history:', error);
        this.showStage(this.stages.INITIAL);
      }
    }
  }

  // Initialize contact form manager
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      window.contactFormManager = new ContactFormManager();
    });
  } else {
    window.contactFormManager = new ContactFormManager();
  }
</script>
