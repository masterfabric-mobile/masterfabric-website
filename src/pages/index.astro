---
// =============================================================================
// IMPORTS
// =============================================================================

// Layout Components
import Layout from "@layouts/layout.astro";
import GitHubProjects from "@components/about/github-projects.astro";
import Container from "@components/layout/container.astro";

// Hero & Landing Components
import ContactSection from "@components/forms/contact-section.astro";
import Welcome from "@components/pages/welcome.astro";

// Solution Components
import RefactorApplication from "@components/pages/refactor-application.astro";

// Brand & Marketing Components
import Logos from "@components/pages/logos.astro";
import CTA from "@components/pages/cta.astro";

// Project Flow Components
import ProjectFlowTimeline from "@components/pages/project-flow-timeline.astro";

// Data imports
import fs from "fs";
import path from "path";

// Load project flow data from JSON file
const projectFlowDataPath = path.join(process.cwd(), "src/data/project-flow.json");
const projectFlowDataContent = fs.readFileSync(projectFlowDataPath, "utf-8");
const projectFlowData = JSON.parse(projectFlowDataContent);
---

<!-- ======================================================================= -->
<!-- MAIN PAGE LAYOUT -->
<!-- ======================================================================= -->
<Layout title="Master Fabric Starter -  Next Project Starts Here">
  <Container>
    <!-- =================================================================== -->
    <!-- CONTACT SECTION -->
    <!-- Content area and contact form for customer acquisition -->
    <!-- =================================================================== -->
    <ContactSection />
    
    <!-- =================================================================== -->
    <!-- PROJECT FLOW TIMELINE -->
    <!-- Dynamic project development process visualization -->
    <!-- =================================================================== -->
    <ProjectFlowTimeline timeline={projectFlowData.timeline} />
    
    <!-- =================================================================== -->
    <!-- WELCOME SECTION -->
    <!-- Introduction and overview of services -->
    <!-- =================================================================== -->
    <Welcome />
    
    <!-- =================================================================== -->
    <!-- REFACTOR APPLICATION -->
    <!-- Application modernization and refactoring services -->
    <!-- =================================================================== -->
    <RefactorApplication />
    <!-- =================================================================== -->
    <!-- GITHUB PROJECTS -->
    <!-- Display showcase of development projects and repositories -->
    <!-- =================================================================== -->
    <GitHubProjects />
    <!-- =================================================================== -->
    <!-- BRAND PARTNERSHIPS -->
    <!-- Display partner logos and testimonials -->
    <!-- =================================================================== -->
    <Logos />
    <!-- =================================================================== -->
    <!-- CALL TO ACTION -->
    <!-- Final conversion section with contact forms or next steps -->
    <!-- =================================================================== -->   
    <CTA/>
  </Container>
</Layout>
