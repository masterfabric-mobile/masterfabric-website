---
import Layout from "@layouts/layout.astro";
import Container from "@components/layout/container.astro";
import Sectionhead from "@components/layout/section-head.astro";
import Button from "@components/ui/button.astro";
import DepartmentCard from "@components/jobs/DepartmentCard.astro";
import BenefitCard from "@components/jobs/BenefitCard.astro";
import HiringStep from "@components/jobs/HiringStep.astro";
import MobileHiringStep from "@components/jobs/MobileHiringStep.astro";
import JobPositionCard from "@components/jobs/JobPositionCard.astro";
import { Icon } from "astro-icon/components";
import fs from "fs";
import path from "path";

// Load jobs data from JSON file
const jobsDataPath = path.join(process.cwd(), "src/data/jobs.json");
const jobsDataContent = fs.readFileSync(jobsDataPath, "utf-8");
const jobsData = JSON.parse(jobsDataContent);

// Load positions data from separate JSON file
const positionsDataPath = path.join(process.cwd(), "src/data/positions.json");
const positionsDataContent = fs.readFileSync(positionsDataPath, "utf-8");
const positionsData = JSON.parse(positionsDataContent);

// Get today's date in a readable format
const today = new Date().toLocaleDateString('en-US', { 
  year: 'numeric', 
  month: 'long', 
  day: 'numeric' 
});
---

<Layout title="Careers - Join Our Team | MasterFabric">
  <!-- Include the CSS file -->
  
  <Container>
    <!-- Header Section -->
    <Sectionhead>
      <Fragment slot="title">{jobsData.sectionHeader.title}</Fragment>
      <Fragment slot="desc">
        <div class="max-w-4xl mx-auto text-center space-y-4">
          {jobsData.sectionHeader.description.map((item) => (
            <p class="text-lg text-gray-600">{item}</p>
          ))}
        </div>
      </Fragment>
    </Sectionhead>

    <!-- Hero Section -->
    <section class="py-8 lg:py-12">
      <div class="text-center mb-12">
        <h1 class="text-4xl lg:text-6xl xl:text-7xl font-bold text-gray-900 leading-tight mb-8">
          <span class="block">{jobsData.hero.title}</span>
          <span class="block text-blue-600 mt-2">{jobsData.hero.subtitle}</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-600 max-w-4xl mx-auto leading-relaxed" set:html={jobsData.hero.description}></p>
      </div>
    </section>

    <!-- Position Detail Modal/Card -->
    <div id="position-detail-modal" class="fixed inset-0 bg-black bg-opacity-50 z-50 hidden">
      <div class="flex items-center justify-center min-h-screen px-4 py-8">
        <div class="bg-white rounded-3xl max-w-4xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">
          <div id="position-detail-content" class="p-8">
            <!-- Content will be dynamically populated -->
          </div>
        </div>
      </div>
    </div>

    <!-- Company Structure Section -->
    <section class="py-12 lg:py-16">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-4">{jobsData.companyStructure.title}</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">{jobsData.companyStructure.description}</p>
      </div>
      
      <!-- Modern Cards Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-6xl mx-auto">
        {jobsData.companyStructure.departments.map((dept, index) => (
          <DepartmentCard department={dept} index={index} />
        ))}
      </div>
    </section>

    <!-- Employee Care Section -->
    <section class="py-16 lg:py-20">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-6">{jobsData.employeeCare.title}</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">{jobsData.employeeCare.description}</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {jobsData.employeeCare.benefits.map((benefit) => (
          <BenefitCard benefit={benefit} />
        ))}
      </div>
    </section>

    <!-- Hiring Process Section -->
    <section class="py-16 lg:py-20 bg-gradient-to-br from-blue-50 to-indigo-50 rounded-3xl mb-20">
      <div class="text-center mb-16">
        <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 mb-6">{jobsData.hiringProcess.title}</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">{jobsData.hiringProcess.description}</p>
      </div>
      
      <!-- Desktop and Tablet - Horizontal Layout -->
      <div class="hidden md:block">
        <div class="relative">
          <!-- Progress Line -->
          <div class="absolute top-16 left-0 right-0 h-1 bg-blue-200 rounded-full">
            <div class="h-full bg-blue-600 rounded-full" style="width: 100%;"></div>
          </div>
          
          <div class="grid grid-cols-4 gap-8 relative">
            {jobsData.hiringProcess.steps.map((step, index) => (
              <HiringStep step={step} />
            ))}
          </div>
        </div>
      </div>
      
      <!-- Mobile - Vertical Layout -->
      <div class="md:hidden space-y-8">
        {jobsData.hiringProcess.steps.map((step, index) => (
          <MobileHiringStep 
            step={step} 
            isLast={index === jobsData.hiringProcess.steps.length - 1} 
          />
        ))}
      </div>
    </section>

    <!-- Open Positions Section -->
    <section class="py-16 lg:py-20">
      <div class="text-center mb-16">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-center gap-4 mb-6">
          <h2 class="text-3xl lg:text-4xl font-bold text-gray-900 text-center lg:text-left">Open Positions</h2>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-orange-100 text-orange-800 w-fit mx-auto lg:mx-0">
            On Development
          </span>
        </div>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">Join our team and help shape the future of mobile application development</p>
      </div>
      
      <!-- Desktop/Tablet - Table View -->
      <div class="hidden lg:block bg-white rounded-2xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-200">
              <tr>
                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Position</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Department</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Location</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Experience</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Salary</th>
                <th class="px-6 py-4 text-left text-sm font-semibold text-gray-900">Posted</th>
                <th class="px-6 py-4 text-right text-sm font-semibold text-gray-900">Action</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              {positionsData.openPositions.map((job) => (
                <tr class="hover:bg-gray-50 transition-colors duration-200">
                  <td class="px-6 py-4">
                    <div>
                      <div class="text-sm font-medium text-gray-900">{job.title}</div>
                      <div class="text-sm text-gray-500">{job.type}</div>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                      {job.department}
                    </span>
                  </td>
                  <td class="px-6 py-4 text-sm text-gray-900">{job.location}</td>
                  <td class="px-6 py-4 text-sm text-gray-900">{job.experience}</td>
                  <td class="px-6 py-4 text-sm text-gray-900">{job.salary}</td>
                  <td class="px-6 py-4 text-sm text-gray-500">
                    {job.posted === 'today' ? today : job.posted}
                  </td>
                  <td class="px-6 py-4 text-right">
                    <button 
                      class="job-apply-btn inline-flex items-center px-3 py-2 border border-transparent text-sm leading-4 font-medium rounded-md text-blue-700 bg-blue-100 hover:bg-blue-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors duration-200"
                      data-job-id={job.id}
                      onclick="selectPosition(this)"
                    >
                      Apply
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
      
      <!-- Mobile - Card View -->
      <div class="lg:hidden space-y-6">
        {positionsData.openPositions.map((job) => (
          <JobPositionCard job={job} today={today} />
        ))}
      </div>
    </section>

    <!-- Application Form Section -->
    <section class="p-10 lg:py-20 bg-gradient-to-br from-gray-900 to-gray-800 rounded-3xl text-white">
      <div class="text-center mb-12">
        <h2 class="text-3xl lg:text-4xl font-bold mb-6">{jobsData.applicationForm.title}</h2>
        <p class="text-xl text-gray-300 mb-4">{jobsData.applicationForm.subtitle}</p>
        <p class="text-gray-300 max-w-3xl mx-auto">{jobsData.applicationForm.description}</p>
      </div>
      
      <div class="max-w-2xl mx-auto">
        <form
          action={jobsData.api.endpoint}
          method="POST"
          id="career-form"
          class="space-y-6"
          enctype="multipart/form-data"
        >
          <input type="hidden" name="access_key" value={jobsData.api.accessKey} />
          <input type="hidden" name="subject" value="New Career Application - MasterFabric" />
          <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-300 mb-2">
                {jobsData.applicationForm.fields.name.label} *
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder={jobsData.applicationForm.fields.name.placeholder}
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>
            
            <div>
              <label for="email" class="block text-sm font-medium text-gray-300 mb-2">
                {jobsData.applicationForm.fields.email.label} *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder={jobsData.applicationForm.fields.email.placeholder}
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-300 mb-2">
                {jobsData.applicationForm.fields.phone.label}
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder={jobsData.applicationForm.fields.phone.placeholder}
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>
            
            <div>
              <label for="experience" class="block text-sm font-medium text-gray-300 mb-2">
                {jobsData.applicationForm.fields.experience.label} *
              </label>
              <input
                type="text"
                id="experience"
                name="experience"
                required
                placeholder={jobsData.applicationForm.fields.experience.placeholder}
                class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
              />
            </div>
          </div>
          
          <div>
            <label for="position" class="block text-sm font-medium text-gray-300 mb-2">
              {jobsData.applicationForm.fields.position.label} *
            </label>
            <select
              id="position"
              name="position"
              required
              class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            >
              <option value="" class="text-gray-900">Select a position...</option>
              {positionsData.openPositions.map((job) => (
                <option value={job.title} class="text-gray-900">{job.title}</option>
              ))}
              <option value="Other" class="text-gray-900">Other / General Application</option>
            </select>
          </div>
          
          <div>
            <label for="portfolio" class="block text-sm font-medium text-gray-300 mb-2">
              {jobsData.applicationForm.fields.portfolio.label}
            </label>
            <input
              type="url"
              id="portfolio"
              name="portfolio"
              placeholder={jobsData.applicationForm.fields.portfolio.placeholder}
              class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>
          
          <div>
            <label for="message" class="block text-sm font-medium text-gray-300 mb-2">
              {jobsData.applicationForm.fields.message.label} *
            </label>
            <textarea
              id="message"
              name="message"
              required
              rows="6"
              placeholder={jobsData.applicationForm.fields.message.placeholder}
              class="w-full px-4 py-3 bg-white/10 border border-white/20 rounded-lg text-white placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent resize-none"
            ></textarea>
          </div>
          
          <div class="text-center">
            <Button 
              type="submit" 
              size="lg" 
              class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-4 px-8 rounded-lg transition-colors duration-200 w-full md:w-auto"
            >
              Submit Application
            </Button>
          </div>
          
          <div id="career-form-result" class="text-center text-sm"></div>
        </form>
      </div>
    </section>

    <!-- Quote Section -->
    <section class="py-16 lg:py-20 text-center">
      <div class="max-w-4xl mx-auto">
        <blockquote class="text-2xl lg:text-3xl font-light text-gray-600 italic leading-relaxed mb-8">
          "{jobsData.quote.text}"
        </blockquote>
        <div class="text-gray-900">
          <p class="font-semibold text-lg">{jobsData.quote.author}</p>
          <p class="text-gray-600">{jobsData.quote.position}</p>
        </div>
      </div>
    </section>
  </Container>

  <!-- Include jobs data and script -->
  <script define:vars={{ jobsData, positionsData }}>
    window.jobsData = jobsData;
    window.positionsData = positionsData;
  </script>
  
  <script src="/src/scripts/jobs.js"></script>
</Layout>

